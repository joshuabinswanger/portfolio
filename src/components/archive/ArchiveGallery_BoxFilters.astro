/* ============================================================
   MOBILE — full-screen filter overlay
   On mobile the Role/Tool/Topic groups open as a full-screen sheet
   that slides up, instead of the desktop bottom-anchored list that
   clips against the fixed bar. Driven by transform/opacity (no grid
   track animation) so it is WebKit/iOS-safe. The collapsed bar still
   shows the active-filter chip row: #active-filters-list stays in
   flow while #group-wrapper is lifted out into a fixed overlay.
   ============================================================ */

@media (--bp-mobile) {

  /* #group-wrapper becomes a fixed overlay (out of flow), so pin the
     remaining bar children to their columns — otherwise the chip row
     would reshuffle into the wrong grid column. */
  #filter-box .bracket-start { grid-column: 1; }
  #filter-box #active-filters-list { grid-column: 3; }
  #filter-box .bracket-end { grid-column: 4; }

  /* Overlay surface — hidden and slid off-screen by default. */
  #group-wrapper {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100dvh;
    max-width: none;
    box-sizing: border-box;
    z-index: 1005;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 4px;
    padding:
      calc(env(safe-area-inset-top, 0px) + 72px) 20px
      calc(env(safe-area-inset-bottom, 0px) + 104px);
    overflow-y: auto;
    overscroll-behavior: contain;
    background-color: var(--bg-color);
    grid-template-rows: none;
    grid-template-columns: none;
    opacity: 0;
    transform: translateY(100%);
    pointer-events: none;
    transition: transform 0.3s ease, opacity 0.25s ease;
  }

  /* Keep the surface full-width and animate the slide on close too. */
  #filter:not(.active) + #filter-box #group-wrapper {
    width: 100vw;
    transition: transform 0.3s ease, opacity 0.25s ease;
  }

  /* Open state (incl. the higher-specificity :has variant). */
  #filter.active + #filter-box #group-wrapper,
  #filter.active + #filter-box:has(.filter-button.mixitup-control-active) #group-wrapper {
    width: 100vw;
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    transition: transform 0.3s ease, opacity 0.25s ease;
  }

  /* Each Role/Tool/Topic group: plain full-width stack. */
  #filter.active + #filter-box .filter-group {
    display: flex;
    flex-direction: column;
    gap: 4px;
    width: 100%;
    height: auto;
    grid-template-rows: none;
    grid-auto-rows: auto;
