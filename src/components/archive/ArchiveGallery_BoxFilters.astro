  }

  #filter.active + #filter-box .filter-title {
    width: 100%;
    text-align: left;
    margin: 12px 0 2px;
  }

  /* Full-width, touch-sized buttons — no height-reveal in the overlay. */
  #filter.active + #filter-box .filter-button {
    width: 100%;
    height: 52px;
