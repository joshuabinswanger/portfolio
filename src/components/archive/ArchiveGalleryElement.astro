---
import { Picture } from "astro:assets";

import "photoswipe/style.css";

import { resolveImageUrl, resolveLocalImage } from "../images/localImages";
import {
  buildArchiveHighResData,
  getArchiveRoleTags,
  getArchiveTagClassString,
  type ArchiveImage,
} from "./utils";

interface Props {
  image: ArchiveImage;
  index: number;
}

const archiveImage = Astro.props.image;
const imageSrc = resolveLocalImage(archiveImage.data.src);
const imageUrl = resolveImageUrl(archiveImage.data.src);
const highResData = await buildArchiveHighResData(archiveImage);
const tagClassString = getArchiveTagClassString(archiveImage);
const convertedRole = getArchiveRoleTags(archiveImage);
---

<div
  class:list={[`archiveElement mix ${tagClassString}`]}
  id={`archiveElement-${Astro.props.index}`}
  data-role={convertedRole}
  data-program={archiveImage.data.metadata?.program}
  data-project={archiveImage.data.metadata?.project || "aaa_noproject"}
  data-date={archiveImage.data.metadata?.year || "2016-01"}
>
  <div id="Image" class:list={["ImageElement"]}>
    <a
      class:list={["photo-link"]}
      id={`index-${Astro.props.index}`}
      href={highResData.url}
      data-pswp-width={highResData.width}
      data-pswp-height={highResData.height}
      target="_blank"
      data-description_title={archiveImage.data.metadata?.description_title}
      data-description_text={archiveImage.data.metadata?.description_text}
      data-link={archiveImage.data.metadata?.link}
    >
      <Picture
        src={imageSrc}
        data-src={imageUrl}
        width={archiveImage.data.width}
        height={archiveImage.data.height}
        sizes="(max-width: 650px) 45vw, (max-width: 1200px) 20vw, 25vw"
        alt={archiveImage.data.metadata?.description_title ?? ""}
        formats={["avif", "webp"]}
        loading="lazy"
        style={`object-position: ${archiveImage.data.metadata?.focus ?? "center"}`}
      />
    </a>
  </div>
</div>

<style>
  @import "../../styles/global.css";

  .archiveElement {
    /* --archive-pad is set per-breakpoint on .archive-grid (GridLayout.astro) and
       scales with the zoom column count; fall back to the old fixed value. */
    padding: var(--archive-pad, 28px);
  }

  a {
    height: 100%;
    grid-column-start: 1;
    /* Grid items default to min-height/min-width: auto, which lets a portrait
       image's intrinsic height grow the 1fr row past the square. Reset to 0 so
       #Image's aspect-ratio wins. */
    min-width: 0;
    min-height: 0;
  }

  picture {
    display: block;
    width: 100%;
    height: 100%;
  }

  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #Image {
    aspect-ratio: 1;
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: 1fr;
    overflow: hidden;
  }

  .mix {
  }
</style>
