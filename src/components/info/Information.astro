---
import TopWrapper from "../../layouts/TopWrapper.astro";
import "../../styles/global.css";
---

<TopWrapper paddingBottom="60px">
  <div id="InfoWrapper">
    <div id="AboutText">
      <p id="rhizome">
        [ Rhizome (/'raɪˌzoʊm/) refers to an underground plant stem from which
        roots and shoots grow. ]
      </p>

      <br />

      <p>
        My name is Joshua Binswanger, I'm a designer and scientific illustrator.
      </p>

      <p>
        Working primarily at the intersection of knowledge transfer and visual
        storytelling, I strive to communicate complex information through
        engaging imagery. I thrive in an environment where I can learn, question
        and discuss new topics and combine them with my visual aesthetic and
        technical expertise.
      </p>

      <p>
        Anchored by a deep fascination with the natural world, my work often
        focuses on accurately and engagingly depicting its intricacies within
        the natural sciences. However I am compelled to engage deeply with
        challenging topics across the full spectrum of scientific fields.
      </p>

      <p>
        I am passionate about enhancing my skills in art, design, and technology
        by mastering new techniques, and try to share my expertise through
        courses, workshops, and online platforms.
      </p>

      <p>
        For collaboration or other inquiries, don't hesitate to contact me: <!--email_off--><a
          href="mailto:info@rhizome.ch"
          id="Email">info@rhizome.ch</a
        ><!--/email_off-->
      </p>
    </div>

    <p id="SelectedClients">
      <strong>Selected Clients:</strong><br /><br />
      ETH<br />
      Hereon @DESY<br />
      University of Zurich<br />
      SLF<br />
      HNE Eberswalde<br />
      LWF Bayern<br />
    </p>

    <p id="Services">
      <strong>Services:</strong><br /><br />
      Scientific Illustration<br />
      3D Design & Visualisation<br />
      Drawing & Illustration<br />
      Infographics<br />
      Workshops<br />
    </p>

    <p id="Personal">
      Browse my comprehensive <a href="/personal">design portfolio</a> featuring
      personal and experimental projects.
    </p>

  </div>
</TopWrapper>

<style>
  @import "../../styles/global.css";
  p {
    font-size: var(--font-size-desktop);
    height: min-content;
    margin-top: 0;

    @media (--bp-mobile) {
      font-size: var(--font-size-mobile);
    }

    @media (--bp-tablet) {
      font-size: var(--font-size-tablet);
    }

    @media (--bp-desktop-wide) {
      font-size: var(--font-size-desktop-wide);
    }
  }

  a {
    color: black;
    text-decoration: underline;
  }

  #InfoWrapper {
    display: grid;
    align-items: center;
    grid-template-columns: 16px 1fr 1fr 1fr 16px;
    grid-auto-rows: min-content;
    column-gap: 16px;
    margin-top: calc(var(--padding-desktop));
    max-height: calc(60vh - var(--padding-desktop));

    max-height: calc(60vh - var(--padding-desktop));

    @media (--bp-mobile) {
      align-self: center;
      max-height: calc(90svh - 3rem - var(--padding-mobile));
      margin: 0 8px;
      margin-top: 0;
      grid-template-columns: 1fr 1fr;
      grid-auto-rows: min-content;
    }

    @media (--bp-tablet) {
      grid-template-columns: auto 1fr 1fr min-content auto;
      grid-column-start: 2;
      margin-top: calc(var(--padding-tablet));
    }

    @media (--bp-desktop-wide) {
      grid-column-start: 2;
      margin-top: calc(var(--padding-desktop-wide));
      align-items: start;
    }
  }

  #AboutText {
    grid-column-start: 2;
    grid-column-end: 4;
    max-width: 111ch;
    max-height: min-content;
    justify-self: left;
    align-self: start;
    letter-spacing: 2px;
    margin: 0;
    padding-bottom: 3rem;

    @media (--bp-mobile) {
      grid-column-start: 1;
      grid-column-end: 3;
      grid-row-start: 1;
      grid-row-end: 2;
    }

    @media (--bp-tablet) {
      padding-right: 1rem;
    }
  }

  #SelectedClients {
    grid-column-start: 2;
    max-width: 23ch;
    font-size: calc(var(--font-size-desktop) - 2px);
    align-self: start;
    letter-spacing: 2px;
    line-height: 1rem;
    height: min-content;
    padding-bottom: 2rem;

    @media (--bp-mobile) {
      font-size: calc(var(--font-size-mobile) - 2px);
      grid-column-start: 1;
      grid-column-end: 2;
    }

    @media (--bp-tablet) {
      font-size: calc(var(--font-size-tablet) - 2px);
    }

    @media (--bp-desktop-wide) {
      font-size: calc(var(--font-size-desktop-wide) - 2px);
    }
  }

  #Services {
    grid-column-start: 3;
    max-width: 33ch;
    align-self: start;
    font-size: calc(var(--font-size-desktop) - 2px);
    letter-spacing: 2px;
    line-height: 1rem;
    height: min-content;

    @media (--bp-mobile) {
      font-size: calc(var(--font-size-mobile) - 2px);
      grid-column-start: 2;
      grid-column-end: 3;
    }

    @media (--bp-tablet) {
      font-size: calc(var(--font-size-tablet) - 2px);
      padding-right: 1rem;
      padding-right: 1rem;
    }

    @media (--bp-desktop-wide) {
      font-size: calc(var(--font-size-desktop-wide) - 2px);
    }
  }

  #Personal {
    grid-column-start: 2;
    grid-column-end: 4;
    align-self: center;

    @media (--bp-mobile) {
      grid-column-start: 1;
    }
  }

  #Email {
    color: black;
  }

  #rhizome {
    font-size: 11px;
    font-family: PowerGrotesk-Light;
    font-style: italic;
    opacity: 0.3;
  }

</style>
