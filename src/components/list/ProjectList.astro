---
import TopWrapper from "../../layouts/TopWrapper.astro";
import { getCollection } from "astro:content";
import { marked } from "marked";
import ImageSlide from "./ImageSlide.astro";
import "keen-slider/keen-slider.min.css";

import { sortProjectsByYear } from "./utils.ts";

const projects = await getCollection("projects");

// Sort
const sortedProjects = sortProjectsByYear(projects);

// make project keep track of its index, like this it can be used by photoswipe
let enrichedProjects = [];
let globalIndex = 0;

for (const entry of sortedProjects) {
  const projectName = entry.data.projectName;
  const startIndex = globalIndex;

  // Fetch galleryImages
  const galleryImages = await getCollection("galleryImages", ({ data }) => {
    const imageProject = data.metadata?.project;
    return imageProject && projectName.includes(imageProject);
  });

  const galleryVideos = await getCollection("images", ({ data }) => {
    return (
      data.mediaType === "video" &&
      data.metadata?.project === projectName &&
      data.metadata.showInProjectGallery === "yes"
    );
  });

  const slidesCount = galleryImages.length + galleryVideos.length;
  globalIndex += slidesCount + 2;

  const projectData = {
    entry,
    projectName,
    startIndex,
    slidesCount,
  };
  enrichedProjects.push(projectData);
}
---

<TopWrapper>
  <div id="list-wrapper">
    <hr />

    {
      enrichedProjects.map(({ entry, startIndex, slidesCount }) => {
        const year = entry.data.year.slice(0, 4);

        return (
          <Fragment>
            <div
              class:list={["ListElement"]}
              id={entry.data.projectName}
              data-project-title={entry.data.title}
              data-project-credits={entry.data.credits}
            >
              <div class:list={["list-element-bar"]}>
                <div class:list={["column1"]}>
                  <div class:list={["year"]}>
                    <>
                      <p>{year}</p>
                      <p>{entry.data.client}</p>
                    </>
                  </div>
                </div>

                <div class:list={["column2"]}>
                  <div class:list={["project-title"]}>
                    <p>{entry.data.title}</p>
                  </div>
                </div>

                <div class:list={["column3"]}>
                  <div class:list={["role"]}>{entry.data.role}</div>
                </div>

                <div class:list={["column4"]}>&darr;</div>
              </div>

              <div class:list={["flip-out"]}>
                <div class:list={["project-slider"]}>
                  <button class:list={["arrow-left"]}>&larr;</button>

                  <div class:list={["project-images"]}>
                    <ImageSlide
                      projectName={entry.data.projectName}
                      startIndex={startIndex}
                      slidesCount={slidesCount}
                    />
                  </div>

                  <button class:list={["arrow-right"]}>&rarr;</button>
                </div>

                <div class:list={["project-description"]}>
                  <div class:list={["description"]}>
                    <Fragment
                      set:html={marked.parse(entry.data.projectDescription)}
                    />
                  </div>
                </div>
              </div>
            </div>

            <hr />
          </Fragment>
        );
      })
    }
  </div>
</TopWrapper>

<!-- Keen Slider -->
<script>
  import KeenSlider, { type KeenSliderInstance } from "keen-slider";
  import "keen-slider/keen-slider.min.css";

  type DestroyableSlider = {
    destroy: () => void;
  };

  // Store slider instances for later destruction
  let keenSlidersStore: Record<string, DestroyableSlider> = {};

  document.addEventListener("astro:page-load", () => {
    const listElements = document.querySelectorAll<HTMLElement>(".ListElement");

    function canPlayInlineVideos() {
      return (
        document.visibilityState === "visible" &&
        document.documentElement.dataset.photoswipeOpen !== "true"
      );
    }

    function pauseVideos(root: ParentNode) {
      root.querySelectorAll("video, mux-video, mux-player").forEach((video) => {
        if ("pause" in video && typeof video.pause === "function") {
          video.pause();
        }
      });
    }

    function playAutoplayVideos(root: ParentNode) {
      root.querySelectorAll("video, mux-video, mux-player").forEach((video) => {
        const mediaLink = video.closest("a[data-media-type='video']");
        const shouldAutoplay =
          mediaLink?.getAttribute("data-mux-autoplay") === "true" ||
          video.hasAttribute("autoplay");

        if (
          shouldAutoplay &&
          "play" in video &&
          typeof video.play === "function"
        ) {
          video.play().catch(() => {});
        }
      });
    }

    function syncVisibleVideos(s: KeenSliderInstance, sliderRoot: HTMLElement) {
      pauseVideos(sliderRoot);

      if (!canPlayInlineVideos()) {
        return;
      }

      s.slides.forEach((slide, idx) => {
        const visibleAmount = s.track.details.slides[idx]?.portion ?? 0;

        if (visibleAmount > 0) {
          playAutoplayVideos(slide);
        }
      });
    }

    listElements.forEach((listEl) => {
      const sliderContainer = listEl.querySelector<HTMLElement>(".project-images");
      const listBar = listEl.querySelector<HTMLElement>(".list-element-bar");
      let sliderInView = false;
      let slider: KeenSliderInstance | null = null;

      if (!sliderContainer || !listBar) {
        return;
      }

      const inlineVisibilityObserver = new IntersectionObserver(
        ([entry]) => {
          sliderInView = Boolean(entry?.isIntersecting);

          if (!slider) {
            return;
          }

          if (sliderInView && listEl.classList.contains("open")) {
            syncVisibleVideos(slider, sliderContainer);
          } else {
            pauseVideos(sliderContainer);
          }
        },
        { threshold: 0.25 },
      );

      inlineVisibilityObserver.observe(listEl);

      document.addEventListener("portfolio:photoswipe-closed", () => {
        if (slider && sliderInView && listEl.classList.contains("open")) {
          syncVisibleVideos(slider, sliderContainer);
        }
      });

      document.addEventListener("visibilitychange", () => {
        if (
          slider &&
          sliderInView &&
          listEl.classList.contains("open") &&
          canPlayInlineVideos()
        ) {
          syncVisibleVideos(slider, sliderContainer);
        } else {
          pauseVideos(sliderContainer);
        }
      });

      // Click on bar
      listBar.addEventListener("click", () => {
        // Toggle the clicked slider
        if (listEl.classList.contains("open")) {
          listEl.classList.remove("open");
          pauseVideos(listEl);

          setTimeout(() => {
            sliderContainer.style.display = "";
          }, 500);
        } else {
          sliderContainer.style.display = "block";
          listEl.classList.add("open");

          // Initialize Keen Slider if not already initialized
          if (
            sliderContainer &&
            !sliderContainer.dataset.keenSliderInitialized
          ) {
            slider = new KeenSlider(sliderContainer, {
              loop: true,
              created: (s) => syncVisibleVideos(s, sliderContainer),
              slideChanged: (s) => syncVisibleVideos(s, sliderContainer),
              animationEnded: (s) => syncVisibleVideos(s, sliderContainer),
              slides: { perView: 3, spacing: 50 },
              breakpoints: {
                "(max-width: 1119px)": {
                  slides: { perView: 2, spacing: 40 },
                },
                "(min-width: 1201px)": {
                  slides: { perView: 3, spacing: 80 },
                },
              },
            });

            // Store slider instance for cleanup
            keenSlidersStore[listEl.id] = slider;

            // Add click event listeners to the arrow buttons
            const arrowLeft = listEl.querySelector<HTMLElement>(".arrow-left");
            const arrowRight = listEl.querySelector<HTMLElement>(".arrow-right");

            if (arrowLeft) {
              arrowLeft.addEventListener("click", (e) => {
                e.stopPropagation(); // Prevent triggering the list bar click
                slider.prev();
              });
            }

            if (arrowRight) {
              arrowRight.addEventListener("click", (e) => {
                e.stopPropagation(); // Prevent triggering the list bar click
                slider.next();
              });
            }

            sliderContainer.dataset.keenSliderInitialized = "true";
          }
        }
      });
    });
  });

  // Clean up sliders before Astro navigates away
  document.addEventListener("astro:before-swap", () => {
    document
      .querySelectorAll("video, mux-video, mux-player")
      .forEach((video) => {
        if ("pause" in video && typeof video.pause === "function") {
          video.pause();
        }
      });

    Object.values(keenSlidersStore).forEach((slider) => {
      if (slider && typeof slider.destroy === "function") {
        slider.destroy();
      }
    });
    keenSlidersStore = {};
  });
</script>

<!-- PhotoSwipe -->
<script>
  import "@mux/mux-player";
  import "@mux/mux-video";
  import PhotoSwipeLightbox from "photoswipe/lightbox";
  import { registerPhotoSwipeCaption } from "../gallery/photoswipeCaption";

  const leftArrowSVGString =
    '<svg aria-hidden="true" class="pswp__icn" viewBox="0 0 155 139" "width="39" height="35"><path d="m0 69 69 69 14-12-45-46h116V58H38l44-44L69 0 0 69Z" style="fill-rule:nonzero"/></svg>';
  const CloseSVGString =
    '<svg aria-hidden="true" class="pswp__icn" viewBox="0 0 139 139" "width="139" height="139"><path d="m69 83-56 55-13-12 56-57L0 14 13 0l56 56 56-56 13 14-55 55 55 57-13 12-56-55Z"/></svg>';

  let lightbox = null;

  function isPhonePortrait() {
    return window.matchMedia("(max-width: 650px) and (orientation: portrait)")
      .matches;
  }

  const MUX_ENV_KEY = import.meta.env.PUBLIC_MUX_ENV_KEY ?? "";

  function escapeHtml(value: string | null) {
    return (value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  function buildMuxPlayerSlide(videoLink: HTMLAnchorElement) {
    const playbackId = videoLink.getAttribute("data-mux-playback-id");
    const poster = videoLink.getAttribute("data-mux-poster");
    const maxResolution = videoLink.getAttribute("data-mux-max-resolution");
    const width = videoLink.getAttribute("data-pswp-width") ?? "16";
    const height = videoLink.getAttribute("data-pswp-height") ?? "9";
    const showControls = videoLink.getAttribute("data-mux-controls") !== "false";
    const autoplay = videoLink.getAttribute("data-mux-autoplay") === "true";
    const loop = videoLink.getAttribute("data-mux-loop") === "true";
    const muted = videoLink.getAttribute("data-mux-muted") === "true";
    const title = escapeHtml(videoLink.getAttribute("data-description_title"));
    const posterAttr = poster ? ` poster="${escapeHtml(poster)}"` : "";
    const maxResolutionAttr = maxResolution
      ? ` max-resolution="${escapeHtml(maxResolution)}"`
      : "";
    const controlsAttr = showControls ? " controls" : "";
    const autoplayAttr = autoplay ? " autoplay" : "";
    const loopAttr = loop ? " loop" : "";
    const mutedAttr = muted ? " muted" : "";
    const envKeyAttr = MUX_ENV_KEY
      ? ` env-key="${escapeHtml(MUX_ENV_KEY)}"`
      : "";
    const muxElement = showControls ? "mux-player" : "mux-video";

    return {
      html: `<div class="pswp__video-slide photoswipeData" style="--video-aspect-ratio: ${escapeHtml(width)} / ${escapeHtml(height)};">
        <${muxElement}
          playback-id="${escapeHtml(playbackId)}"
          stream-type="on-demand"
          metadata-video-id="${escapeHtml(playbackId)}"
          metadata-video-title="${title}"
          ${controlsAttr}
          ${autoplayAttr}
          ${loopAttr}
          ${mutedAttr}
          playsinline
          ${posterAttr}
          ${maxResolutionAttr}
          ${envKeyAttr}
        ></${muxElement}>
      </div>`,
      width: videoLink.getAttribute("data-pswp-width"),
      height: videoLink.getAttribute("data-pswp-height"),
      description_title: videoLink.getAttribute("data-description_title"),
      description_text: videoLink.getAttribute("data-description_text"),
      link: videoLink.getAttribute("data-link"),
    };
  }

  function pauseAllVideos(root: ParentNode = document) {
    root.querySelectorAll("video, mux-video, mux-player").forEach((video) => {
      if ("pause" in video && typeof video.pause === "function") {
        video.pause();
      }
    });
  }

  function playAutoplayVideos(root: ParentNode) {
    root.querySelectorAll("video, mux-video, mux-player").forEach((video) => {
      if (
        video.hasAttribute("autoplay") &&
        "play" in video &&
        typeof video.play === "function"
      ) {
        video.play().catch(() => {});
      }
    });
  }

  function playActivePhotoSwipeVideo() {
    window.requestAnimationFrame(() => {
      const activeSlide =
        document.querySelector<HTMLElement>(".pswp__item--active") ??
        document.querySelector<HTMLElement>(".pswp__item[aria-hidden='false']") ??
        document.querySelector<HTMLElement>(".pswp__video-slide");

      if (activeSlide) {
        playAutoplayVideos(activeSlide);
      }
    });
  }

  document.addEventListener("astro:page-load", () => {
    const projectElements = document.querySelectorAll<HTMLElement>(".ListElement");

    if (projectElements.length === 0) {
      return;
    }

    let photoswipeCustomData = [];

    projectElements.forEach((projectEl) => {
      let galleryData = [];

      // Add project title slide
      const projectTitle =
        projectEl.getAttribute("data-project-title") || "Default Project Title";

      const portfolioElementNameElement = {
        html: `<div class="pswp__project-title-slide photoswipeData"><p class="pswp__project-title ">${projectTitle}</p></div>`,
      };

      galleryData.push(portfolioElementNameElement);

      // Add image elements
      const imageLinks = projectEl.querySelectorAll<HTMLAnchorElement>(".ImageElement a");

      imageLinks.forEach((imgLink) => {
        if (imgLink.getAttribute("data-media-type") === "video") {
          galleryData.push(buildMuxPlayerSlide(imgLink));
          return;
        }

        const photoswipeImageData = {
          src: imgLink.getAttribute("href"),
          width: imgLink.getAttribute("data-pswp-width"),
          height: imgLink.getAttribute("data-pswp-height"),
          alt: imgLink.getAttribute("data-description_text"),
          description_title: imgLink.getAttribute("data-description_title"),
          description_text: imgLink.getAttribute("data-description_text"),
          link: imgLink.getAttribute("data-link"),
        };

        galleryData.push(photoswipeImageData);
      });

      // Add project info slide
      const ProjectInfoWrapper = projectEl.querySelector<HTMLElement>(
        ".project-description",
      );
      const projectDescription = ProjectInfoWrapper
        ? ProjectInfoWrapper.innerHTML
        : "";

      const projectCredits =
        projectEl.getAttribute("data-project-credits") || "";

      const projectInfoEl = {
        html: `<div class="pswp__project-info-slide-wrapper photoswipeData keen-slider__slide">
          <div class="pswp__project-info-slide">
            <div class="pswp__project-info">
              ${projectDescription}
            </div>
            <div class="pswp__project-details">
              ${projectCredits}
            </div>
          </div>
        </div>`,
      };

      galleryData.push(projectInfoEl);
      photoswipeCustomData.push(galleryData);
    });

    const flatData = photoswipeCustomData.flat();

    const options = {
      arrowPrevSVG: leftArrowSVGString,
      arrowNextSVG: leftArrowSVGString,
      closeSVG: CloseSVGString,

      dataSource: flatData,

      initialZoomLevel: "fit" as const,
      bgOpacity: 0.95,
      zoom: false,

      mainClass: "pswp--custom-bg pswp--custom-icon-colors",

      paddingFn: () => {
        if (isPhonePortrait()) {
          return { top: 0, bottom: 0, left: 10, right: 10 };
        } else {
          return { top: 20, bottom: 40, left: 100, right: 100 };
        }
      },

      showHideAnimationType: "fade" as const,
      pswpModule: () => import("photoswipe"),
    };

    // Destroy any existing lightbox before creating a new one
    if (lightbox) {
      lightbox.destroy();
      lightbox = null;
    }

    lightbox = new PhotoSwipeLightbox(options);

    registerPhotoSwipeCaption(lightbox);
    lightbox.on("beforeOpen", () => {
      document.documentElement.dataset.photoswipeOpen = "true";
      pauseAllVideos();
    });
    lightbox.on("change", () => {
      pauseAllVideos();
      playActivePhotoSwipeVideo();
    });
    lightbox.on("close", () => {
      pauseAllVideos();
      document.documentElement.dataset.photoswipeOpen = "false";
      document.dispatchEvent(new CustomEvent("portfolio:photoswipe-closed"));
    });
    lightbox.on("destroy", () => {
      pauseAllVideos();
      document.documentElement.dataset.photoswipeOpen = "false";
      document.dispatchEvent(new CustomEvent("portfolio:photoswipe-closed"));
    });

    lightbox.init();
    window.pswpLightbox = lightbox;
  });

  // Clean up PhotoSwipe before navigation
  document.addEventListener("astro:before-swap", () => {
    pauseAllVideos();
    document.documentElement.dataset.photoswipeOpen = "false";

    if (lightbox) {
      lightbox.destroy();
      lightbox = null;
    }
  });
</script>

<style>
  @import "../../styles/global.css";

  #list-wrapper {
    display: grid;
    grid-auto-rows: min-content min-content;
    grid-column-start: 2;
    margin: 1rem 0;
    align-items: center;
    margin-top: var(--padding-desktop);
    width: 100%;

    @media (--bp-mobile) {
      margin-top: var(--padding-mobile);
      padding-left: 0px;
      grid-column-start: 1;
    }
    @media (--bp-tablet) {
      margin-top: var(--padding-tablet);
    }
    @media (--bp-desktop-wide) {
      margin-top: var(--padding-desktop-wide);
    }
  }

  .ListElement {
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: 52px auto;
    transition: all 0.5s ease;
    cursor: pointer;
    overflow: hidden;
  }

  .list-element-bar {
    display: grid;
    grid-template-columns: 1.5fr 2fr 1fr 48px;
    column-gap: 16px;

    @media (--bp-mobile) {
      grid-template-columns: 9ch 1fr 0px 48px;
    }
  }

  .flip-out {
    margin: 0px 0px 0px 0px;
    grid-column-start: 1;
    grid-column-end: 6;
    max-height: 0;
    overflow: hidden;
    transition: all 0.5s ease;
    display: grid;
    grid-template-rows: min-content min-content;
    grid-template-columns: 1fr 1fr 1fr;
  }

  .project-slider {
    margin: 0px 0px 0px 0px;
    grid-row-start: 1;
    grid-column-start: 1;
    grid-column-end: 4;
    overflow: hidden;
    transition: all 0.5s ease;
    display: grid;
    grid-template-rows: 1fr;
    grid-template-columns: 40px 1fr 40px;
  }

  .project-description {
    display: grid;
    justify-content: center;
    padding: 40px;
    margin-top: 16px;
    grid-row-start: 2;
    grid-column-start: 1;
    grid-column-end: 4;
    grid-template-rows: min-content min-content;
    column-gap: 80px;
    grid-template-columns: 660px 1fr;

    @media (--bp-mobile) {
      grid-template-columns: 1fr;
    }
  }

  .title {
    grid-row-start: 1;
    grid-column-start: 1;
  }

  .subtitle {
    grid-row-start: 1;
    grid-column-start: 1;
  }

  .description {
    grid-row-start: 1;
    grid-column-start: 1;
  }

  .credits {
    grid-row-start: 2;
    grid-column-start: 1;
    align-items: start;
  }

  table tbody td {
    vertical-align: top;
    padding: 5px;
  }

  table th {
    padding: 5px;
    text-align: left;
    vertical-align: top;
  }

  table {
    border-collapse: collapse;
    width: 100%;
  }

  .arrow-left,
  .arrow-right {
    all: unset;
    font-size: 22px;
    height: 40px;
    text-justify: center;
    text-align: center;
    background-color: #fbf9f44c;
    width: stretch;
    cursor: pointer;
    z-index: 1011;
    align-self: center;
  }

  .arrow-left {
    grid-row-start: 1;
    grid-column-start: 1;
  }

  .arrow-right {
    grid-row-start: 1;
    grid-column-start: 3;
    justify-self: flex-end;
  }

  .project-images {
    display: none;
    grid-row-start: 1;
    grid-column-start: 2;
    grid-column-end: 3;
    overflow-x: hidden;
  }

  .ListElement.open .flip-out {
    display: grid;
    margin: 8px 0px 16px 0px;
    max-height: 800px;
    margin-top: 1rem;
    margin-bottom: 1rem;
    overflow: visible;
  }

  hr {
    align-self: center;
    margin: 0;
    width: 100%;
  }

  p {
    margin: 0;
  }

  .column1 {
    grid-column-start: 1;
    font-size: 12px;
    display: grid;
    align-items: center;
  }

  .year {
    display: grid;
    grid-template-columns: 40px 1fr;
  }

  .year p:nth-child(1) {
    font-family: PowerGrotesk-Medium;
  }

  .year p:nth-child(2) {
    @media (--bp-mobile) {
      display: none;
    }
  }

  .column2 {
    grid-column-start: 2;
    align-content: center;
    align-items: center;
    align-self: center;
  }

  .project-title {
    font-family: PowerGrotesk-Medium;
    font-size: 21px;

    @media (--bp-mobile) {
      font-size: 19px;
    }
  }

  .column3 {
    grid-column-start: 3;
    font-size: 12px;
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
    justify-items: end;
  }

  .role {
    width: fit-content;
    @media (--bp-mobile) {
      display: none;
    }
  }

  .column4 {
    grid-column-start: 4;
    font-size: 22px;
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
    justify-items: center;
    transform: rotatez(0deg);
    transition: transform 0.25s ease-out 0.125s;
  }

  .ListElement.open > .list-element-bar > .column4 {
    transform: rotatez(180deg);
  }

  :global(.pswp__video-slide) {
    display: grid;
    width: 100%;
    height: 100%;
    place-items: center;
  }

  :global(.pswp__video-slide mux-player),
  :global(.pswp__video-slide mux-video) {
    width: 100%;
    max-width: min(100%, 1600px);
    max-height: 100%;
    aspect-ratio: var(--video-aspect-ratio, 16 / 9);
    object-fit: contain;
    --media-object-fit: contain;
  }
</style>
