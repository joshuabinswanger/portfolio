---
import { CldImage } from "astro-cloudinary";

const mobileFlowerFiles = import.meta.glob(
  "/src/assets/projects/flower_splat/mobile_flower_splat_avif_sequence/*.avif",
  { eager: true, query: "?url" },
);

const desktopFlowerFiles = import.meta.glob(
  "/src/assets/projects/flower_splat/desktop_flower_splat_avif_sequence/*.avif",
  { eager: true, query: "?url" },
);

const mobileFlowerUrls = Object.values(mobileFlowerFiles)
  .map((mod: any) => mod.default)
  .sort()
  .reverse();

const desktopFlowerUrls = Object.values(desktopFlowerFiles)
  .map((mod: any) => mod.default)
  .sort()
  .reverse();
---

<div id="scrolly-container">
  <!-- #region Section: Intro (chapters 1–2) -->
  <div id="panel-intro" class="scrolly-panel split-panel">
    <!-- chapter 1 -->
    <div class="text-wrapper text-p1">
      <h1 class="text-block left-align intro-static">Hi,</h1>
      <h1 class="text-block intro-static">mein Name ist Joshua Binswanger.</h1>
      <p class="text-block intro-reveal-1">
        Ich übersetze Wissen in ästhetische Bilder.
      </p>
      <p class="text-block intro-reveal-1">
        Dafür verbinde ich visuelles Design mit technischem Know-how und mache
        komplexe Inhalte intuitiv greifbar.
      </p>

      <div class="scroll-indicator">
        <span>Scroll</span>
        <span class="arrow">&darr;</span>
      </div>
    </div>

    <!-- Images are siblings of text-p1 so they animate independently -->
    <div class="img-stack img-quercus">
      <video
        autoplay
        muted
        loop
        playsinline
        aria-label="Eiche VDB Volume Rendering"
      >
        <source
          src="https://res.cloudinary.com/rhizomech/video/upload/f_webm,vc_vp9/v1772652991/Eiche_VDB_0001_h265_l14cyb.webm"
          type="video/webm"
        />
        <source
          src="https://res.cloudinary.com/rhizomech/video/upload/v1772652991/Eiche_VDB_0001_h265_l14cyb.mp4"
          type="video/mp4"
        />
      </video>
      <div class="img-caption">
        <h2>Ob Darstellungen mikroskopischer Strukturen...<br /></h2>
        <p>
          Ein nur 0.3mm langer Ausschnitt von Eichenholz, mit klar ersichtlichen
          Gefässen und Zellen. Basierend auf einem Mikro-CT-Scan des Deutschen
          Elektronen-Synchrotrons (DESY).
        </p>
      </div>
    </div>

    <!-- Intro Buchdrucker -->
    <div class="img-stack img-buchdrucker">
      <CldImage
        src="Borkenkaefer_Gallery_2_zdvtwp"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="Borkenkäfer Infoposter"
      />
      <div class="img-caption">
        <h2>Illustrationen für Wissenstransfer...<br /></h2>
        <p>
          Informationsposter über den Buchdrucker und wie man eine der grössten
          Gefahren für unsere Wälder erkennt.
        </p>
      </div>
    </div>

    <!-- Intro Fire -->
    <div class="img-stack img-fire">
      <CldImage
        src="Fire_2020_mvjojb"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="Boreale Feuer 2020"
      />
      <div class="img-caption">
        <h2>Visualisierung von Daten...<br /></h2>
        <p>
          Visualisierung der verbrannten Fläche des borealen Waldes im Jahr
          2020. Aufgrund des Klimawandels finden Waldbrände immer weiter
          nördlich statt und setzen enorme Mengen an CO2 frei. Datensatz
          basierend auf dieser <a
            href="https://essd.copernicus.org/articles/17/3599/2025/"
            target="_blank"
            class="inline-link">Publikation</a
          >.
        </p>
      </div>
    </div>

    <div class="img-stack img-ub-intro">
      <video
        autoplay
        muted
        loop
        playsinline
        aria-label="UB Zürich Jahresbericht 2025"
      >
        <source
          src="https://res.cloudinary.com/rhizomech/video/upload/f_webm,vc_vp9/UB_Zuerich_Jahresbericht25_grgopa.webm"
          type="video/webm"
        />
        <source
          src="https://res.cloudinary.com/rhizomech/video/upload/f_mp4,vc_h264/UB_Zuerich_Jahresbericht25_grgopa.mp4"
          type="video/mp4"
        />
      </video>
      <div class="img-caption">
        <h2>oder Animationen für das Web.<br /></h2>
        <p>Interaktiver Jahresbericht für die Universitätsbibliothek Zürich.</p>
      </div>
    </div>

    <div class="text-wrapper text-intro-after">
      <p class="text-block">
        Nun will ich mein breites Spektrum an Fähigkeiten für aktuelle und
        gesellschaftsrelevante Themen nutzen.
      </p>
      <p class="text-block">
        Die NZZ setzt dabei neue Massstäbe mit ihrer inhaltlichen und visuellen
        Exzellenz – und genau dort will ich hin.
      </p>
    </div>
  </div>
  <!-- #endregion -->

  <!-- #region Section: Work (chapters 3–4) -->

  <div id="panel-work" class="scrolly-panel split-panel">
    <!-- chapter 3 -->
    <div class="text-wrapper text-p3-intro">
      <h1 class="text-block work-title">Arbeiten</h1>
      <p class="text-block">
        In meiner Arbeit fokussiere ich mich auf die wissenschaftliche
        Illustration. Dabei ist es meine Stärke, die visuelle Essenz aus
        komplexen Inhalten zu destillieren.
      </p>
    </div>
    <!-- chapter 3 images -->

    <div class="img-stack img-pheno">
      <CldImage
        src="Phenological_Shift_GalleryImage1_cjmvqe"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="Phenological Shift"
      />
      <div class="img-caption">
        <h2>
          So vermittle ich in Visual Abstracts Forschungsergebnisse...<br />
        </h2>
        <p>
          Illustration zur klimawandelbedingten Verschiebung des
          Pflanzenwachstums in den Alpen.
        </p>
      </div>
    </div>

    <div class="img-stack img-eth-vis-1">
      <CldImage
        src="ETHVisualisations_GalleryPic1_hnzfw1"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="ETH Visualisation 1"
      />

      <div class="img-caption">
        <h2>
          erstelle Prozessgrafiken für wissenschaftliche Papers...<br />
        </h2>
        <p>
          Visualisierung neuester Materialforschung für die ETH Complex
          Materials Group.
        </p>
      </div>
    </div>

    <div class="img-stack img-microbiome">
      <CldImage
        src="Microbiome_OLMA_ttmkmz"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="Microbiome OLMA"
      />
      <div class="img-caption">
        <h2>
          oder illustriere Themen für ein breiteres Publikum.<br />
        </h2>
        <p>Mikrobiom-Illustration für eine ETH Ausstellung an der OLMA.</p>
      </div>
    </div>

    <div class="text-wrapper text-p3-conclusion">
      <p class="text-block">
        Dabei weiss ich besonders die enge Kooperation mit Forschenden zu
        schätzen. Denn die stärksten Arbeiten entstehen im Austausch mit
        Menschen, die für ihre Themen brennen.
      </p>
      <p class="text-block">
        Denselben Fokus auf inhaltliche Auseinandersetzung nehme ich bei der NZZ
        wahr, und ich will nun meinen Teil dazu beitragen.
      </p>
    </div>
  </div>
  <!-- #endregion -->

  <!-- #region Section: Werdegang -->
  <div id="panel-werdegang" class="scrolly-panel split-panel">
    <!-- chapter 5 -->
    <div class="text-wrapper text-p5-1">
      <h2 class="text-block werdegang-titel">Werdegang</h2>
      <p class="text-block">
        Meine Neugier in Kombination mit der Faszination für neue Technologien
        war schon immer die treibende Kraft in meiner gestalterischen
        Entwicklung.
      </p>
    </div>
    <div class="img-stack img-illustration-1">
      <CldImage
        src="Illustration_GalleryImages_1_sihglc"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="Illustration 1"
      />
      <div class="img-caption">
        <h2>
          In meinem Bachelor in Knowledge Visualisation habe ich mein
          handwerkliches Fundament erworben...<br />
        </h2>
        <p>
          Besonders die Illustration von Menschen fasziniert mich bis heute.
        </p>
      </div>
    </div>
    <div class="img-stack img-wood-12">
      <CldImage
        src="StructureofWood_Gallery_12_rbvqux"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="Structure of Wood"
      />
      <div class="img-caption">
        <h2>
          und mich vertieft mit sachlichen Inhalten beschäftigt.<br />
        </h2>
        <p>
          Darstellung der Mikrostruktur von Holz. Dazu musste ich Informationen
          aus Sachbüchern und Papers zusammenbringen.
        </p>
      </div>
    </div>

    <!-- chapter 6 -->
    <div class="text-wrapper text-p6">
      <p class="text-block">
        Die 3D-Visualisierung ist jedoch seither zu meiner grossen Leidenschaft
        geworden.
      </p><p class="text-block">
        Mich reizt die Herausforderung, neue Technologien zu verstehen und damit
        zeitgemässe Bilder zu gestalten.
      </p>
    </div>
    <div class="img-stack img-bacteria">
      <CldImage
        src="blender_bacteria_o8jyby"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="Blender Bacteria"
      />
      <div class="img-caption">
        <h2>Von 3D-Modelling, -Texturing und -Rendering...<br /></h2>
        <p>In Blender erstelltes Bakterienmodell.</p>
      </div>
    </div>

    <div class="img-stack img-gjermundbu">
      <CldImage
        src="Gjermundbu_GalleryImages_1_sco2yz"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="UZH Blender Kurs"
      />
      <div class="img-caption">
        <h2>zur Handhabung von 3D-Scans und -Daten...<br /></h2>
        <p>
          3D-Rekonstruktion des Gjermundbu-Helms, aus frei verfügbaren Scandaten
          entstanden.
        </p>
      </div>
    </div>

    <div class="img-stack img-gamedesign">
      <video
        autoplay
        muted
        loop
        playsinline
        aria-label="Game Design 101 – prozedurale Animation"
      >
        <source
          src="https://res.cloudinary.com/rhizomech/video/upload/f_webm,vc_vp9/GameDesign101_1080p_eoaems.webm"
          type="video/webm"
        />
        <source
          src="https://res.cloudinary.com/rhizomech/video/upload/f_mp4,vc_h264/GameDesign101_1080p_eoaems.mp4"
          type="video/mp4"
        />
      </video>
      <div class="img-caption">
        <h2>über prozedurale Animation in Houdini...<br /></h2>
        <p>Key Visual für die Workshop-Reihe "Game Design 101" an der UZH.</p>
      </div>
    </div>

    <div class="img-stack img-uzh-blender">
      <CldImage
        src="UZHBlenderCourse_1_r6kaar"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="UZH Blender Kurs"
      />
      <div class="img-caption">
        <h2>bis hin zur Lehre an der Universität.<br /></h2>
        <p>
          Key Visual für meinen Blender-Workshop an der Universität Zürich
          (UZH).
        </p>
      </div>
    </div>

    <!-- chapter 7 -->
    <div class="text-wrapper text-p7-1">
      <p class="text-block">
        Wie man Wissen und Geschichten visuell vermitteln kann, ist für mich zur
        zentralen Frage geworden.
      </p>
      <p class="text-block">
        So fesseln mich z.B. die Scrollytelling-Geschichten der NZZ – eine
        perfekte Kombination aus inhaltlicher Tiefe und visueller Vermittlung.
      </p>
      <p class="text-block">
        Deswegen setze ich mich vertieft mit modernen Web-Formaten auseinander,
        um diese zu verstehen und selber Inhalte digital erlebbar zu machen.
      </p>
    </div>

    <div class="img-stack img-xylo">
      <CldImage
        src="XylopediaInsta4_hjbuf8"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="Xylopedia iPad App"
      />
      <div class="img-caption">
        <h2>Angefangen beim Design interaktiver 3D-Applikationen...<br /></h2>
        <p>App zur Vermittlung der Holzstrukturen an der HNE Eberswalde.</p>
      </div>
    </div>

    <div class="img-stack img-augmedi">
      <CldImage
        src="Houdini_Scripts_hd7d5e"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="Augmedi AG – Houdini Scripts für anatomische 3D-Modelle"
      />
      <div class="img-caption">
        <h2>
          über die Erstellung von detaillierten anatomischen Modellen...<br />
        </h2>
        <p>
          In meiner Rolle als Technical Artist bei der <a
            href="https://www.augmedi.com/"
            target="_blank"
            class="inline-link">Augmedi AG</a
          > verantworte ich die 3D-Scans von menschlichen Körpern und deren Aufbereitung
          für unsere Lernapp.
        </p>
      </div>
    </div>

    <div class="img-stack img-portfolio-video">
      <video autoplay muted loop playsinline aria-label="Portfolio">
        <source
          src="https://res.cloudinary.com/rhizomech/video/upload/f_webm,vc_vp9/Portfolio_lc2mft.webm"
          type="video/webm"
        />
        <source
          src="https://res.cloudinary.com/rhizomech/video/upload/f_mp4,vc_h264/Portfolio_lc2mft.mp4"
          type="video/mp4"
        />
      </video>
      <div class="img-caption">
        <h2>bis hin zum Entwickeln ganzer Webseiten.<br /></h2>
        <p>
          Mein persönliches Portfolio habe ich von Grund auf selbst entwickelt.
        </p>
      </div>
    </div>

    <div class="text-wrapper text-block portfolio-link">
      <a
        href="/"
        class="portfolio-logo-btn"
        aria-label="rhizome.ch"
        target="_blank"
      >
        &rarr; rhizome.ch
      </a>
    </div>
  </div>
  <!-- #endregion -->

  <!-- #region Section: Zukunft -->
  <div id="panel-zukunft" class="scrolly-panel split-panel">
    <div class="text-wrapper text-p8-1">
      <p class="text-block text-p8-2">
        Die NZZ nimmt mit ihrem Visual Storytelling eine klare Vorreiterrolle in
        der heutigen Medienlandschaft ein.
      </p>
      <p class="text-block text-p8-3">
        Und genau dazu möchte ich nun beitragen. Ob Newsroom-Grafiken, komplexe
        Visualisierungen oder die visuelle Aufbereitung von Daten – mit meinem
        technischen Repertoire bin ich dafür bestens gewappnet.
      </p>
      <p class="text-block text-p8-4">
        Deswegen bewerbe ich mich als Volontär bei NZZ Visuals, um von Ihrem
        Team zu lernen und gemeinsam den visuellen Journalismus von morgen zu
        prägen.
      </p>

      <div class="text-wrapper text-p8-5">
        <h1 class="text-block">Vielen Dank für Ihre Zeit.</h1>
      </div>

      <div class="img-stack img-flower-canvas">
        <canvas id="flower-canvas"></canvas>
      </div>
    </div>

    <div
      id="image-sequences"
      data-flower-mobile={JSON.stringify(mobileFlowerUrls)}
      data-flower-desktop={JSON.stringify(desktopFlowerUrls)}
    >
    </div>
  </div>
  <!-- #endregion -->

  <!-- Progress bar is a sibling of all panels so panel opacity doesn't affect it -->
  <div id="scrolly-progress">
    <span class="progress-word active" data-section="intro">Intro</span>
    <span></span>
    <span class="progress-word" data-section="work">Arbeiten</span>
    <span></span>
    <span class="progress-word" data-section="werdegang">Werdegang</span>
    <span></span>
    <span class="progress-word" data-section="zukunft">Zukunft</span>
  </div>
</div>
<script>
  // #region Imports & Setup
  import Lenis from "lenis";
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);
  // #endregion

  // #region Lenis Smooth Scroll
  const lenis = new Lenis({
    lerp: 0.15,
    wheelMultiplier: 1.3,
    smoothWheel: true,
  });
  lenis.on("scroll", ScrollTrigger.update);
  gsap.ticker.add((time) => {
    lenis.raf(time * 1000);
  });
  // #endregion

  // #region Master Timeline & Progress Update
  const masterTl = gsap.timeline({
    scrollTrigger: {
      trigger: "#scrolly-container",
      start: "top top",
      end: "+=2700%",
      scrub: 0.8,
      pin: true,
      snap: {
        snapTo: "labelsDirectional",
        duration: { min: 0.4, max: 1 },
        delay: 0.2,
        ease: "power2.inOut",
      },
      onUpdate: (self) => {
        const tl = self.animation;
        const time = tl.time();
        const labels = tl.labels;
        let active = "intro";
        if (time >= labels["chapter-8"]) active = "zukunft";
        else if (time >= labels["chapter-5"]) active = "werdegang";
        else if (time >= labels["chapter-3"]) active = "work";
        document.querySelectorAll(".progress-word").forEach((el) => {
          el.classList.toggle("active", el.dataset.section === active);
        });
      },
    },
  });
  // #endregion

  // #region Flower Splat Canvas
  const dataIsland = document.getElementById("image-sequences");
  const isDesktop = window.matchMedia("(min-width: 1024px)").matches;
  const flowerUrls = JSON.parse(
    isDesktop
      ? dataIsland.dataset.flowerDesktop || "[]"
      : dataIsland.dataset.flowerMobile || "[]",
  );

  const flowerCanvas = document.getElementById(
    "flower-canvas",
  ) as HTMLCanvasElement;
  const flowerCtx = flowerCanvas.getContext("2d");
  const flowerImages = [];
  const flowerPlayhead = { frame: 0 };

  flowerUrls.forEach((url) => {
    const img = new window.Image();
    img.src = url;
    flowerImages.push(img);
  });

  if (flowerImages.length > 0) {
    const setFlowerCanvasSize = () => {
      flowerCanvas.width = flowerImages[0].naturalWidth;
      flowerCanvas.height = flowerImages[0].naturalHeight;
      renderFlower();
    };
    if (flowerImages[0].complete) {
      setFlowerCanvasSize();
    } else {
      flowerImages[0].onload = setFlowerCanvasSize;
    }
  }

  const renderFlower = () => {
    if (flowerImages.length === 0) return;
    flowerCtx.clearRect(0, 0, flowerCanvas.width, flowerCanvas.height);
    const frame = Math.min(
      Math.max(Math.round(flowerPlayhead.frame), 0),
      flowerImages.length - 1,
    );
    if (isDesktop) {
      flowerCtx.globalAlpha = Math.min(flowerPlayhead.frame / 10, 1);
    }
    flowerCtx.drawImage(
      flowerImages[frame],
      0,
      0,
      flowerCanvas.width,
      flowerCanvas.height,
    );
    if (isDesktop) {
      flowerCtx.globalAlpha = 1;
    }
  };
  // #endregion

  // #region GSAP Helper Functions
  // Helper functions
  let snapLabelCount = 0;

  const slideIn = (selector, sync = false, snap = true) => {
    const result = masterTl.fromTo(
      selector,
      { y: "70vh", opacity: 0 },
      { y: 0, opacity: 1, duration: 1, ease: "power2.out" },
      sync ? "<" : "-=0.2",
    );
    if (snap) masterTl.addLabel(`snap-${snapLabelCount++}`, ">");
    return result;
  };
  const fadeIn = (selector, sync = false, snap = true) => {
    const result = masterTl.fromTo(
      selector,
      { scale: 0.8, opacity: 0 },
      { scale: 1, opacity: 1, duration: 1, ease: "power2.out" },
      sync ? "<" : "-=0.2",
    );
    if (snap) masterTl.addLabel(`snap-${snapLabelCount++}`, ">");
    return result;
  };

  const slideOut = (selector, sync = false) => {
    return masterTl.to(
      selector,
      { y: "-70vh", opacity: 0, duration: 0.7 },
      sync ? "<" : "+=0.2",
    );
  };

  const fadeOut = (selector, sync = false) => {
    return masterTl.to(
      selector,
      { scale: 0.8, opacity: 0, duration: 0.5 },
      sync ? "<" : "+=0.2",
    );
  };
  // #endregion

  // #region Initial States & Animations
  // Scroll Indicator Animation
  const scrollIndicatorTween = gsap.to(".scroll-indicator", {
    opacity: 1,
    y: 50,
    duration: 1.2,
    delay: 0.5,
    repeat: -1,
    yoyo: true,
    ease: "power1.out",
  });

  // #region GSAP Timeline Sequencing

  gsap.set(".intro-static", { opacity: 1, y: 0 });
  gsap.set(".intro-reveal-1", { opacity: 0, y: 0 });
  gsap.set("#scrolly-progress", { opacity: 0 });
  gsap.set("#panel-intro", { opacity: 1 });

  // #region Chapter 1: Intro — text then 3 images then closing text
  masterTl.addLabel("chapter-1");
  slideIn(".intro-reveal-1");
  slideOut(".text-p1");
  masterTl.to("#scrolly-progress", { opacity: 1, duration: 0.6 }, "<");

  slideIn(".img-quercus", true);
  fadeOut(".img-quercus");
  fadeIn(".img-buchdrucker", true);
  fadeOut(".img-buchdrucker");
  fadeIn(".img-fire", true);
  fadeOut(".img-fire");
  fadeIn(".img-ub-intro", true);
  fadeOut(".img-ub-intro");
  fadeIn(".text-intro-after", true);
  slideOut(".text-intro-after");
  // #endregion

  // #region Chapter 3: Work — panel-intro stays visible; panel-work overlays it
  masterTl.addLabel("chapter-3");
  masterTl.to("#panel-work", { opacity: 1, duration: 0.05 });
  slideIn(".text-p3-intro", true);
  slideOut(".text-p3-intro");
  slideIn(".img-pheno", true);
  fadeOut(".img-pheno");
  fadeIn(".img-eth-vis-1", true);
  fadeOut(".img-eth-vis-1");
  fadeIn(".img-microbiome", true);
  slideOut(".img-microbiome");
  slideIn(".text-p3-conclusion", true);
  slideOut(".text-p3-conclusion");
  // #endregion

  // #region Chapter 5: Werdegang — fade out panel-intro (takes panel-work with it)
  masterTl.addLabel("chapter-5");
  masterTl.to("#panel-werdegang", { opacity: 1, duration: 0.05 }, "<");
  masterTl.to("#panel-intro", { opacity: 0, duration: 0.05 }, "<");
  slideIn(".text-p5-1", true);
  slideOut(".text-p5-1");
  slideIn(".img-illustration-1", true);
  fadeOut(".img-illustration-1");
  fadeIn(".img-wood-12", true);
  slideOut(".img-wood-12");
  // #endregion

  // #region Chapter 6: Technologie & 3D
  masterTl.addLabel("chapter-6");
  slideIn(".text-p6", true);
  slideOut(".text-p6");
  masterTl.to({}, { duration: 0.25 });
  slideIn(".img-bacteria", true);
  fadeOut(".img-bacteria");
  fadeIn(".img-gjermundbu", true);
  fadeOut(".img-gjermundbu");
  fadeIn(".img-gamedesign", true);
  fadeOut(".img-gamedesign");
  fadeIn(".img-uzh-blender", true);
  slideOut(".img-uzh-blender");
  // #endregion

  // #region Chapter 7: Digitale Formate & Web
  masterTl.addLabel("chapter-7");
  slideIn(".text-p7-1", true);
  slideOut(".text-p7-1");
  slideIn(".img-xylo", true);
  fadeOut(".img-xylo");
  fadeIn(".img-augmedi", true);
  fadeOut(".img-augmedi");
  fadeIn(".img-portfolio-video", true);
  fadeOut(".img-portfolio-video");
  slideIn(".portfolio-link", true);
  slideOut(".portfolio-link");
  // #endregion

  // #region Chapter 8: Zukunft — 3 sequential text reveals, then flower + finale
  masterTl.addLabel("chapter-8");
  masterTl.to("#panel-zukunft", { opacity: 1, duration: 0.05 });
  masterTl.to("#panel-werdegang", { opacity: 0, duration: 0.05 }, "<");
  masterTl.to(".text-p8-1", { opacity: 1, duration: 0.05 }, "<");
  slideIn(".text-p8-2", true);
  slideIn(".text-p8-3");
  slideIn(".text-p8-4");
  slideOut(".text-p8-2");
  slideOut(".text-p8-3", true);
  slideOut(".text-p8-4", true);
  masterTl.to(
    flowerPlayhead,
    {
      frame: (flowerImages.length || 1) - 1,
      snap: "frame",
      ease: "none",
      onUpdate: renderFlower,
      duration: 1.5,
    },
    "-=0.5",
  );
  fadeIn(".img-flower-canvas", true);
  slideIn(".text-p8-5");
  masterTl.addLabel(`text-snap-${snapLabelCount++}`);
  masterTl.addLabel("end");
  // #endregion

  // #endregion

  // #region Event Listeners
  // Hide scroll indicator on first scroll
  const hideScrollIndicator = () => {
    scrollIndicatorTween.kill();
    gsap.to(".scroll-indicator", {
      opacity: 0,
      duration: 0.3,
      ease: "power1.out",
    });
    lenis.off("scroll", hideScrollIndicator);
  };
  lenis.on("scroll", hideScrollIndicator);

  // Clickable Progress Words
  document.querySelectorAll(".progress-word").forEach((word) => {
    word.addEventListener("click", (e) => {
      const target = e.currentTarget as HTMLElement;
      const section = target.dataset.section;
      let label = "chapter-1";
      if (section === "work") label = "chapter-3";
      else if (section === "werdegang") label = "chapter-5";
      else if (section === "zukunft") label = "chapter-8";

      if (masterTl.scrollTrigger) {
        const scrollPos = masterTl.scrollTrigger.labelToScroll(label) + 700;
        lenis.scrollTo(scrollPos, {
          duration: 3,
          easing: (t) =>
            t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2,
        });
      }
    });
  });
  // #endregion
</script>

