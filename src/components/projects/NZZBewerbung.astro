---
import { CldImage } from "astro-cloudinary";

const flowerFiles = import.meta.glob(
  "/src/assets/projects/flower_splat/flower_splat_avif_sequence/*.avif",
  { eager: true, query: "?url" },
);

const flowerUrls = Object.values(flowerFiles)
  .map((mod: any) => mod.default)
  .sort()
  .reverse();
---

<div id="scrolly-container">
  <!-- #region Section: Intro (chapters 1–2) -->
  <div id="panel-intro" class="scrolly-panel split-panel">
    <!-- chapter 1 -->
    <div class="text-wrapper text-p1">
      <h1 class="text-block left-align intro-static">Hi,</h1>
      <h1 class="text-block intro-static">mein Name ist Joshua Binswanger.</h1>
      <p class="text-block intro-reveal">
        Als wissenschaftlicher Illustrator bewege ich mich an der Schnittstelle
        von visuellem Design und Technologie.
      </p>
    </div>

    <div class="scroll-indicator">
      <span>Scroll</span>
      <span class="arrow">&darr;</span>
    </div>

    <div class="img-stack img-quercus">
      <CldImage
        src="QuercusRobur_VolumeRendering_epzxld"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="Quercus Robur Volume Rendering"
      />
      <p class="img-caption">
        Visualisierung eines Mikro-CT-Scans von Eichenholz: Die am Deutschen
        Elektronen-Synchrotron (DESY) gewonnenen Daten bilden die Grundlage
        einer interaktiven Lern-App für Studierende der Holzwissenschaften.
      </p>
    </div>

    <!-- Intro Gjermundbu -->
    <div class="img-stack img-gjermundbu">
      <CldImage
        src="Gjermundbu_GalleryImages_1_sco2yz"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="Gjermundbu Helmet"
      />
      <p class="img-caption">
        Diese 3D-Rekonstruktion des Gjermundbu-Helms zeigt diesen Ansatz: Aus
        rohen, öffentlichen Scandaten entstand durch mein technisches Know-how
        ein interaktives Echtzeit-3D-Modell.
      </p>
    </div>

    <!-- chapter Buchdrucker -->
    <div class="text-wrapper text-p2">
      <p class="text-block">
        Am wertvollsten ist meine Arbeit jedoch, wenn sie Wissen für ein breites
        Publikum zugänglich macht.
      </p>
    </div>

    <div class="img-stack img-buchdrucker-1">
      <CldImage
        src="Buchdrucker_djaxkc"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="Buchdrucker"
      />
    </div>
    <div class="img-stack img-borkenkaefer">
      <CldImage
        src="Borkenkaefer_Gallery_2_zdvtwp"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="Borkenkäfer Infoposter"
      />
      <p class="img-caption">
        Wie bei diesem Infoposter über den Borkenkäfer (<em>Ips typographus</em
        >)...
      </p>
    </div>
    <div class="img-stack img-microbiome">
      <CldImage
        src="Microbiome_OLMA_ttmkmz"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="Microbiome OLMA"
      />
      <p class="img-caption">oder dem Mikrobiom-Poster für die OLMA.</p>
    </div>
  </div>
  <!-- #endregion -->

  <!-- #region Section: Work (chapters 3–4) -->
  <div id="panel-work" class="scrolly-panel split-panel">
    <!-- chapter 3 -->
    <div class="text-wrapper text-p3">
      <p class="text-block">
        Mein Fokus liegt auf der wissenschaftlichen Illustration. Es reizt mich,
        abstrakte Sachverhalte in neuartige Bildwelten zu übersetzen.
      </p>
    </div>
    <!-- chapter 4 -->
    <div class="text-wrapper text-p4-1">
      <p class="text-block">
        Meine Stärke dabei: Ich arbeite mich selbstständig und tief in
        hochkomplexe Themen ein und übersetze diese passgenau für die jeweilige
        Zielgruppe.
      </p>
    </div>

    <!-- chapter 3 images -->
    <div class="img-stack img-eth-vis-3">
      <CldImage
        src="ETHVisualisations_Gallery_3_myrndw"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="ETH Visualisation 3"
      />
      <p class="img-caption">
        Dabei pobiere ich immer ein starkes Visual zu erkennen und als zentraler
        Punkt im Bild einzubinden.
      </p>
    </div>
    <div class="img-stack img-eth-vis-1">
      <CldImage
        src="ETHVisualisations_GalleryPic1_hnzfw1"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="ETH Visualisation 1"
      />
      <p class="img-caption">
        Bei Projekten wie den Paper-Figures für die ETH-Materialforschung
        balanciere ich höchste Informationsdichte auf kleinstem Raum.
      </p>
    </div>

    <!-- chapter 4 images -->
    <div class="text-wrapper text-p4-2">
      <p class="text-block">
        Dabei verbinde ich zunehmend klassische Datenvisualisierung mit
        illustrativen Elementen.
      </p>
    </div>

    <div class="img-stack img-pheno">
      <CldImage
        src="Phenological_Shift_GalleryImage1_cjmvqe"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="Phenological Shift"
      />
      <p class="img-caption">
        Ein Beispiel dafür ist dieser Visual Abstract, der den «Phenological
        Shift» – die klimawandelbedingte Verschiebung des Pflanzenwachstums in
        den Alpen – visuell auf den Punkt bringt.
      </p>
    </div>
  </div>
  <!-- #endregion -->

  <!-- #region Section: Werdegang (chapters 5–7) -->
  <div id="panel-werdegang" class="scrolly-panel split-panel">
    <!-- chapter 5 -->
    <div class="text-wrapper text-p5-1">
      <p class="text-block">
        Ein kurzer Blick auf meinen Werdegang: Neugier und neue Technologien
        treiben mich an.
      </p>
    </div>
    <div class="text-wrapper text-p5-2">
      <p class="text-block">
        In meinem Bachelor an der ZHdK habe ich mir jene analytischen und
        handwerklichen Grundlagen erarbeitet, auf denen mein heutiges Schaffen
        aufbaut.
      </p>
    </div>
    <div class="img-stack img-wood-12">
      <CldImage
        src="StructureofWood_Gallery_12_rbvqux"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="Structure of Wood"
      />
      <p class="img-caption">Von der Mikrostruktur des Holzes...</p>
    </div>
    <div class="img-stack img-wood-5">
      <CldImage
        src="StructureofWood_Gallery_5_g1x7ry"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="Structure of Wood 5"
      />
    </div>
    <div class="img-stack img-illustration-1">
      <CldImage
        src="FigureDrawing_Gallery_23_dnrpi3"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="Figure Drawing"
      />
      <p class="img-caption">bis zur anatomischen Darstellung des Menschen:</p>
    </div>
    <div class="img-stack img-figure">
      <CldImage
        src="Illustration_GalleryImages_1_sihglc"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="Illustration 1"
      />
    </div>

    <!-- chapter 6 -->
    <div class="text-wrapper text-p6">
      <p class="text-block">
        Mein wichtigstes Werkzeug ist heute das 3D-Design.
      </p>
    </div>
    <div class="img-stack img-bacteria">
      <CldImage
        src="blender_bacteria_o8jyby"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="Blender Bacteria"
      />
      <p class="img-caption">
        Hier fasziniert mich nicht nur die präzise 3D-Modellierung...
      </p>
    </div>
    <div class="img-stack img-gamedesign">
      <video
        autoplay
        muted
        loop
        playsinline
        aria-label="Game Design 101 – prozedurale Animation"
      >
        <source
          src="https://res.cloudinary.com/rhizomech/video/upload/f_webm,vc_vp9/GameDesign101_1080p_eoaems.webm"
          type="video/webm"
        />
        <source
          src="https://res.cloudinary.com/rhizomech/video/upload/f_mp4,vc_h264/GameDesign101_1080p_eoaems.mp4"
          type="video/mp4"
        />
      </video>
      <p class="img-caption">und prozedurale Animation.</p>
    </div>
    <div class="img-stack img-houdini-scripts">
      <CldImage
        src="Houdini_Scripts_hd7d5e"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="Houdini Scripts"
      />
      <p class="img-caption">
        Momentan bin ich für die 3D-Scanning Pipline beim Medizin-Start-Up
        Augmedi verantwortlich. Dabei habe ich mich vertieft mit Scripting und
        KI-Tools auseinandergesetzt.
      </p>
    </div>
    <div class="img-stack img-augmedi-approach">
      <CldImage
        src="Augmedi_Appraoch_tuka73"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="Augmedi Approach"
      />
      <p class="img-caption">
        Das Resultat ist ein Workflow, der es mir erlaubt hunderte von Scans
        alleine zu verarbeiten und trorzdem dem hohen Qualitätsanspruch der
        Ärzte gerecht wird.
      </p>
    </div>

    <!-- chapter 7 -->
    <div class="text-wrapper text-p7-1">
      <p class="text-block">
        Da Wissen heute primär digital konsumiert wird, entwickle ich
        interaktive Formate.
      </p>
    </div>
    <div class="img-stack img-xylo">
      <CldImage
        src="XylopediaInsta4_hjbuf8"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="Xylopedia iPad App"
      />
      <p class="img-caption">Von der Echtzeit-3D-App «Xylopedia» fürs iPad</p>
    </div>
    <div class="text-wrapper text-p7-2">
      <p class="text-block">bis hin zu modernen Web-Technologien:</p>
    </div>
    <div class="img-stack img-ub-video">
      <video
        autoplay
        muted
        loop
        playsinline
        aria-label="UB Zürich Jahresbericht 2025"
      >
        <source
          src="https://res.cloudinary.com/rhizomech/video/upload/f_webm,vc_vp9/UB_Zuerich_Jahresbericht25_grgopa.webm"
          type="video/webm"
        />
        <source
          src="https://res.cloudinary.com/rhizomech/video/upload/f_mp4,vc_h264/UB_Zuerich_Jahresbericht25_grgopa.mp4"
          type="video/mp4"
        />
      </video>
      <p class="img-caption">
        Animierte Website für den Jahresbericht der Universitätsbibliothek
        Zürich
      </p>
    </div>
    <div class="text-wrapper text-p7-3">
      <p class="text-block">
        Mein Fokus verlagert sich zunehmend auf interaktives Web-Design, da es
        dem Publikum den direktesten Zugang bietet.
      </p>
    </div>
    <div class="img-stack img-portfolio-video">
      <video autoplay muted loop playsinline aria-label="Portfolio">
        <source
          src="https://res.cloudinary.com/rhizomech/video/upload/f_webm,vc_vp9/Portfolio_lc2mft.webm"
          type="video/webm"
        />
        <source
          src="https://res.cloudinary.com/rhizomech/video/upload/f_mp4,vc_h264/Portfolio_lc2mft.mp4"
          type="video/mp4"
        />
      </video>
      <p class="img-caption">
        Deswegen habe ich mein Portfolio von Grundauf selbst programmiert.
      </p>
    </div>
  </div>
  <!-- #endregion -->

  <!-- #region Section: Zukunft (chapter 8) -->
  <div id="panel-zukunft" class="scrolly-panel split-panel">
    <div class="text-wrapper text-p8-1">
      <p class="text-block">
        Nun möchte ich mein breites Skillset nutzen, um gesellschaftsrelevante
        Themen im journalistischen Kontext visuell erfahrbar zu machen.
      </p>
      <p class="text-block text-p8-2">
        Die analytische Klarheit und visuelle Eleganz von NZZ Visuals sind für
        mich der Benchmark im Informationsdesign.
      </p>

      <p class="text-block text-p8-3">
        Deshalb bewerbe ich mich für das Volontariat: Um von eurem Team zu
        lernen, meine technischen Workflows effizient in den rasanten
        redaktionellen Alltag zu übersetzen und gemeinsam neue digitale Formate
        zu prägen.
      </p>
    </div>

    <div class="text-wrapper text-p8-4">
      <h1 class="text-block">Vielen Dank für ihre Zeit.</h1>
    </div>

    <div class="img-stack img-flower-canvas">
      <canvas id="flower-canvas"></canvas>
    </div>
  </div>
  <!-- #endregion -->

  <!-- #region Scrolly Progress & Data -->
  <div id="scrolly-progress">
    <span class="progress-word active" data-section="intro">Intro</span>
    <span></span>
    <span class="progress-word" data-section="work">Work</span>
    <span></span>
    <span class="progress-word" data-section="werdegang">Werdegang</span>
    <span></span>
    <span class="progress-word" data-section="zukunft">Zukunft</span>
  </div>

  <div id="image-sequences" data-flower={JSON.stringify(flowerUrls)}></div>
  <!-- #endregion -->
</div>

<script>
  // #region Imports & Setup
  import Lenis from "lenis";
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);
  // #endregion

  // #region Lenis Smooth Scroll
  const lenis = new Lenis({ lerp: 0.1, wheelMultiplier: 1, smoothWheel: true });
  lenis.on("scroll", ScrollTrigger.update);
  gsap.ticker.add((time) => {
    lenis.raf(time * 1000);
  });
  // #endregion

  // #region Master Timeline & Progress Update
  const masterTl = gsap.timeline({
    scrollTrigger: {
      trigger: "#scrolly-container",
      start: "top top",
      end: "+=7000%",
      scrub: 0.15,
      pin: true,
      markers: false,
      snap: {
        snapTo: "labels",
        duration: { min: 0.2, max: 3 },
        delay: 0.2,
        ease: "power1.inOut",
      },
      onUpdate: (self) => {
        const tl = self.animation;
        const time = tl.time();
        const labels = tl.labels;
        let active = "intro";
        if (time >= labels["chapter-8"]) active = "zukunft";
        else if (time >= labels["chapter-5"]) active = "werdegang";
        else if (time >= labels["chapter-3"]) active = "work";
        document.querySelectorAll(".progress-word").forEach((el) => {
          el.classList.toggle("active", el.dataset.section === active);
        });
      },
    },
  });
  // #endregion

  // #region Flower Splat Canvas
  const dataIsland = document.getElementById("image-sequences");
  const flowerUrls = JSON.parse(dataIsland.dataset.flower || "[]");

  const flowerCanvas = document.getElementById(
    "flower-canvas",
  ) as HTMLCanvasElement;
  const flowerCtx = flowerCanvas.getContext("2d");
  const flowerImages = [];
  const flowerPlayhead = { frame: 0 };

  flowerUrls.forEach((url) => {
    const img = new window.Image();
    img.src = url;
    flowerImages.push(img);
  });

  if (flowerImages.length > 0) {
    flowerImages[0].onload = () => {
      flowerCanvas.width = flowerImages[0].naturalWidth;
      flowerCanvas.height = flowerImages[0].naturalHeight;
      renderFlower();
    };
  }

  const renderFlower = () => {
    if (flowerImages.length === 0) return;
    flowerCtx.clearRect(0, 0, flowerCanvas.width, flowerCanvas.height);
    const frame = Math.min(
      Math.max(Math.round(flowerPlayhead.frame), 0),
      flowerImages.length - 1,
    );
    flowerCtx.drawImage(
      flowerImages[frame],
      0,
      0,
      flowerCanvas.width,
      flowerCanvas.height,
    );
  };
  // #endregion

  // #region GSAP Helper Functions
  // Helper functions
  let snapLabelCount = 0;

  const showText = (selector, sync = false) => {
    const result = masterTl.to(
      selector,
      { opacity: 1, y: 0, duration: 0.5, ease: "power2.out" },
      sync ? "<" : "+=0.2",
    );
    masterTl.addLabel(`snap-${snapLabelCount++}`, ">");
    return result;
  };

  const hideText = (selector, sync = false) => {
    return masterTl.to(
      selector,
      { y: "-70vh", opacity: 0, duration: 0.5 },
      sync ? "<" : "+=0.2",
    );
  };

  const showImg = (selector, sync = false) => {
    const imageTl = gsap.timeline();
    imageTl
      .to(selector, { y: "0%", duration: 0.5 })
      .to(selector, { opacity: 1, duration: 0.4 }, ">-0.4");
    const result = masterTl.add(imageTl, sync ? "<" : "-=0.2");
    masterTl.addLabel(`snap-${snapLabelCount++}`, ">");
    return result;
  };

  const zoomFadeInImg = (selector, sync = false) => {
    const result = masterTl.fromTo(
      selector,
      { y: "0%", opacity: 0, scale: 1.4 },
      { opacity: 1, duration: 0.8, scale: 1, ease: "power2.out" },
      sync ? "<" : "-=0.5",
    );
    masterTl.addLabel(`snap-${snapLabelCount++}`, ">");
    return result;
  };

  const hideImg = (selector, sync = false) => {
    return masterTl.to(
      selector,
      { y: "-100%", opacity: 0, duration: 0.5 },
      sync ? "<" : "+=0.2",
    );
  };
  // #endregion

  // #region Initial States & Animations
  // Scroll Indicator Animation
  const scrollIndicatorTween = gsap.to(".scroll-indicator", {
    opacity: 1,
    y: 50,
    duration: 1.2,
    delay: 0.5,
    repeat: -1,
    yoyo: true,
    ease: "power1.out",
  });

  const hideScrollIndicator = () => {
    scrollIndicatorTween.kill();
    gsap.to(".scroll-indicator", { opacity: 0, duration: 0.3 });
    lenis.off("scroll", hideScrollIndicator);
  };
  lenis.on("scroll", hideScrollIndicator);

  // #region GSAP Timeline Sequencing
  // ------------------------------------------
  // GSAP Timeline Sequencing
  // ------------------------------------------

  gsap.set(".text-p1", { opacity: 1, y: 0 });
  gsap.set(".intro-reveal", { opacity: 0, y: 0 });

  // #region Section: Intro (chapters 1–2)
  masterTl.addLabel("chapter-1");
  masterTl.set("#panel-intro", { opacity: 1 });
  masterTl.to("#scrolly-progress", { opacity: 1, duration: 0.2 });
  showText(".intro-reveal");
  hideText(".text-p1");
  hideText(".text-p1-1", true);
  masterTl.to(".scroll-indicator", { opacity: 0, duration: 0.2 }, "<");

  showImg(".img-quercus", true);
  hideImg(".img-quercus");
  zoomFadeInImg(".img-gjermundbu", true);
  hideImg(".img-gjermundbu");

  masterTl.addLabel("chapter-2");
  showText(".text-p2", true);
  hideText(".text-p2");
  showImg(".img-buchdrucker-1", true);
  hideImg(".img-buchdrucker-1");
  zoomFadeInImg(".img-borkenkaefer", true);
  hideImg(".img-borkenkaefer");
  zoomFadeInImg(".img-microbiome", true);
  hideImg(".img-microbiome");
  // #endregion

  // #region Section: Work (chapters 3–4)
  masterTl.addLabel("chapter-3");
  masterTl.to("#panel-work", { opacity: 1, duration: 0.05 });
  masterTl.to("#panel-intro", { opacity: 0, duration: 0.05 }, "<");
  showText(".text-p3", true);
  hideText(".text-p3");

  masterTl.addLabel("chapter-4");
  showText(".text-p4-1", true);
  hideText(".text-p4-1");

  showImg(".img-eth-vis-3", true);
  hideImg(".img-eth-vis-3");
  zoomFadeInImg(".img-eth-vis-1", true);
  hideImg(".img-eth-vis-1");

  showImg(".img-eth-vis-2", true);
  hideImg(".img-eth-vis-2");
  showText(".text-p4-2", true);
  hideText(".text-p4-2");
  zoomFadeInImg(".img-pheno", true);
  hideImg(".img-pheno");
  // #endregion

  // #region Section: Werdegang (chapters 5–7)
  masterTl.addLabel("chapter-5");
  masterTl.to("#panel-werdegang", { opacity: 1, duration: 0.05 });
  masterTl.to("#panel-work", { opacity: 0, duration: 0.05 }, "<");
  showText(".text-p5-1", true);
  hideText(".text-p5-1");
  showText(".text-p5-2", true);
  hideText(".text-p5-2");
  showImg(".img-wood-12", true);
  hideImg(".img-wood-12");
  zoomFadeInImg(".img-wood-5", true);
  hideImg(".img-wood-5");
  zoomFadeInImg(".img-illustration-1", true);
  hideImg(".img-illustration-1");
  zoomFadeInImg(".img-figure", true);
  hideImg(".img-figure");
  // #endregion

  // #region Section: Chapter 6
  masterTl.addLabel("chapter-6");
  showText(".text-p6", true);
  hideText(".text-p6");
  showImg(".img-bacteria", true);
  hideImg(".img-bacteria");
  zoomFadeInImg(".img-gamedesign", true);
  hideImg(".img-gamedesign");
  zoomFadeInImg(".img-houdini-scripts", true);
  hideImg(".img-houdini-scripts");
  zoomFadeInImg(".img-augmedi-approach", true);
  hideImg(".img-augmedi-approach");
  // #endregion

  // #region Section: Chapter 7
  masterTl.addLabel("chapter-7");
  showText(".text-p7-1", true);
  hideText(".text-p7-1");
  showImg(".img-xylo", true);
  hideImg(".img-xylo");
  showText(".text-p7-2", true);
  hideText(".text-p7-2");
  zoomFadeInImg(".img-ub-video", true);
  hideImg(".img-ub-video");
  showText(".text-p7-3", true);
  hideText(".text-p7-3");
  showImg(".img-portfolio-video", true);
  hideImg(".img-portfolio-video");
  // #endregion

  // #region Section: Zukunft (chapter 8)
  masterTl.addLabel("chapter-8");
  masterTl.to("#panel-zukunft", { opacity: 1, duration: 0.05 });
  masterTl.to("#panel-werdegang", { opacity: 0, duration: 0.05 }, "<");
  showText(".text-p8-1", true);
  showText(".text-p8-2");
  showText(".text-p8-3");
  hideText(".text-p8-1");
  hideText(".text-p8-2", true);
  hideText(".text-p8-3", true);
  masterTl.to(
    flowerPlayhead,
    {
      frame: (flowerImages.length || 1) - 1,
      snap: "frame",
      ease: "none",
      onUpdate: renderFlower,
      duration: 1.5,
    },
    "-=1",
  );

  showImg(".img-flower-canvas", true);
  masterTl.to(
    "#panel-zukunft .text-p8-4",
    { opacity: 1, y: 0, duration: 0.8, ease: "power2.out" },
    "-=0.5",
  );
  masterTl.addLabel(`text-snap-${snapLabelCount++}`);
  // #endregion
  // #endregion

  // #region Event Listeners
  // Clickable Progress Words
  document.querySelectorAll(".progress-word").forEach((word) => {
    word.addEventListener("click", (e) => {
      const target = e.currentTarget as HTMLElement;
      const section = target.dataset.section;
      let label = "chapter-1";
      if (section === "work") label = "chapter-3";
      else if (section === "werdegang") label = "chapter-5";
      else if (section === "zukunft") label = "chapter-8";

      if (masterTl.scrollTrigger) {
        const scrollPos = masterTl.scrollTrigger.labelToScroll(label) + 700;
        lenis.scrollTo(scrollPos, { duration: 4 });
      }
    });
  });
  // #endregion
</script>

