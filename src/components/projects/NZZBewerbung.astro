---
import { CldImage } from "astro-cloudinary";
import rhizomeLogo from "@assets/Rhizome_Logo_208h.jpg";

const flowerFiles = import.meta.glob(
  "/src/assets/projects/flower_splat/flower_splat_avif_sequence/*.avif",
  { eager: true, query: "?url" },
);

const flowerUrls = Object.values(flowerFiles)
  .map((mod: any) => mod.default)
  .sort()
  .reverse();
---

<div id="scrolly-container">
  <!-- #region Section: Intro (chapters 1–2) -->
  <div id="panel-intro" class="scrolly-panel split-panel">
    <!-- chapter 1 -->
    <div class="text-wrapper text-p1">
      <h1 class="text-block left-align intro-static">Hi,</h1>
      <h1 class="text-block intro-static">mein Name ist Joshua Binswanger.</h1>
      <p class="text-block intro-reveal-1">
        Ich übersetze Wissen in ästhetische Bilder. Dazu bewege ich mich mit
        Leidenschaft zwischen Design und Technologie und mache komplexe Inhalte
        intuitiv erlebbar.
      </p>
      <p class="text-block intro-reveal-2">
        Nun will ich meine diversen Fähigkeiten für die Vermittlung
        gesellschaftsrelevanter Themen einsetzen.
      </p>

      <div class="scroll-indicator">
        <span>Scroll</span>
        <span class="arrow">&darr;</span>
      </div>
    </div>

    <!-- Images are siblings of text-p1 so they animate independently -->
    <div class="img-stack img-quercus">
      <video
        autoplay
        muted
        loop
        playsinline
        aria-label="Eiche VDB Volume Rendering"
      >
        <source
          src="https://res.cloudinary.com/rhizomech/video/upload/f_webm,vc_vp9/v1772652991/Eiche_VDB_0001_h265_l14cyb.webm"
          type="video/webm"
        />
        <source
          src="https://res.cloudinary.com/rhizomech/video/upload/v1772652991/Eiche_VDB_0001_h265_l14cyb.mp4"
          type="video/mp4"
        />
      </video>
      <div class="img-caption">
        <h2>Ob Visualisierung komplexer Strukturen...<br /></h2>
        <p>
          Rendering von Eichenholz auf mikroskopischer Ebene. Basierend auf
          einem Mikro-CT-Scan des Deutschen Elektronen-Synchrotrons (DESY).
        </p>
      </div>
    </div>

    <!-- Intro Buchdrucker -->
    <div class="img-stack img-buchdrucker">
      <CldImage
        src="Borkenkaefer_Gallery_2_zdvtwp"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="Borkenkäfer Infoposter"
      />
      <div class="img-caption">
        <h2>Illustrationen für Wissenstransfer...<br /></h2>
        <p>
          Poster über den Buchdrucker zur Informationsvermittlung an Förster.
        </p>
      </div>
    </div>

    <div class="img-stack img-ub-intro">
      <video
        autoplay
        muted
        loop
        playsinline
        aria-label="UB Zürich Jahresbericht 2025"
      >
        <source
          src="https://res.cloudinary.com/rhizomech/video/upload/f_webm,vc_vp9/UB_Zuerich_Jahresbericht25_grgopa.webm"
          type="video/webm"
        />
        <source
          src="https://res.cloudinary.com/rhizomech/video/upload/f_mp4,vc_h264/UB_Zuerich_Jahresbericht25_grgopa.mp4"
          type="video/mp4"
        />
      </video>
      <div class="img-caption">
        <h2>oder animierten Webseiten.<br /></h2>
        <p>
          Design und Animation (mit Rive) für die Universitätsbibliothek Zürich.
        </p>
      </div>
    </div>

    <!-- #endregion -->

    <!-- #region Section: Work (chapters 3–4) -->
    <div class="text-wrapper text-titel-work">
      <h1>Work</h1>
    </div>

    <div id="panel-work" class="scrolly-panel split-panel">
      <!-- chapter 3 -->
      <div class="text-wrapper text-p3-intro">
        <p class="text-block">
          Als wissenschaftlicher Illustrator übersetze ich komplexe Sachverhalte
          in visuell ansprechende Bilder.
        </p>
        <p class="text-block">
          Meine Stärke liegt darin, die inhaltliche und visuelle Essenz zu
          destillieren.
        </p>
      </div>
      <!-- chapter 3 images -->

      <div class="img-stack img-pheno">
        <CldImage
          src="Phenological_Shift_GalleryImage1_cjmvqe"
          width={1200}
          sizes="(max-width: 768px) 100vw, 50vw"
          alt="Phenological Shift"
        />
        <div class="img-caption">
          <h2>
            In Visual Abstracts kombiniere ich inhaltliche Tiefe mit visuellem
            Interesse...<br />
          </h2>
          <p>
            So wie in der Zusammenfassung der klimawandelbedingten Verschiebung
            des Pflanzenwachstums in den Alpen.
          </p>
        </div>
      </div>

      <div class="img-stack img-eth-vis-1">
        <CldImage
          src="ETHVisualisations_GalleryPic1_hnzfw1"
          width={1200}
          sizes="(max-width: 768px) 100vw, 50vw"
          alt="ETH Visualisation 1"
        />

        <div class="img-caption">
          <h2>
            und bei der wissenschaftlichen Paper-Illustration balanciere ich
            höchste Informationsdichte auf kleinstem Raum.<br />
          </h2>
          <p>
            Für die ETH Complex Materials Group visualisiere ich die neusten
            Funde in der Materialforschung.
          </p>
        </div>
      </div>
    </div>

    <div class="img-stack img-microbiome">
      <CldImage
        src="Microbiome_OLMA_ttmkmz"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="Microbiome OLMA"
      />
      <div class="img-caption">
        <h2>
          Oder ich fokussiere mich auf die ästhetische Darstellung für
          Wissenstransfer an ein breiteres Publikum.<br />
        </h2>
        <p>
          Illustration für den Wissentransfer über das Mikrobiom an der OLMA.
        </p>
      </div>
    </div>

    <div class="text-wrapper text-p3-conclusion">
      <p class="text-block">
        Dabei schätze ich besonders die enge Kooperation mit Wissenschaftlern.
      </p>
      <p class="text-block">
        Ich bin überzeugt, dass die stärksten Arbeiten im Austausch entstehen –
        mit Menschen, die genauso für ein Thema brennen wie ich.
      </p>
    </div>
  </div>
  <!-- #endregion -->

  <!-- #region Section: Werdegang (chapters 5–7) -->
  <div id="panel-werdegang" class="scrolly-panel split-panel">
    <!-- chapter 5 -->
    <div class="text-wrapper text-p5-1">
      <p class="text-block">
        Ein kurzer Blick auf meinen Werdegang. Meine Neugier und Faszination für
        neue Technologien ist eine treibende Kraft in meiner gestalterischen
        Entwicklung.
      </p>
    </div>
    <div class="img-stack img-illustration-1">
      <CldImage
        src="Illustration_GalleryImages_1_sihglc"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="Illustration 1"
      />
      <div class="img-caption">
        <h2>
          In meinem Bachelor in Knowledge Visualisation an der ZHdK habe ich
          mein handwerkliches Fundament erworben...<br />
        </h2>
        <p>Besonders die Illustration von Menschen fasziniert mich.</p>
      </div>
    </div>
    <div class="img-stack img-wood-12">
      <CldImage
        src="StructureofWood_Gallery_12_rbvqux"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="Structure of Wood"
      />
      <div class="img-caption">
        <h2>
          und mich begonnen intensiver mit der Darstellung von Inhalten zu
          beschäftigen.<br />
        </h2>
        <p>Darstellung der Mikrostruktur von Holz.</p>
      </div>
    </div>

    <!-- chapter 6 -->
    <div class="text-wrapper text-p6">
      <p class="text-block">
        Danach habe ich mein technisches Hauptaugenmerk auf die
        3D-Visualisierung fokussiert. Ich baue mein Repertoire stetig aus.
        Mittlerweile umfasst es:
      </p>
    </div>
    <div class="img-stack img-bacteria">
      <CldImage
        src="blender_bacteria_o8jyby"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="Blender Bacteria"
      />
      <div class="img-caption">
        <h2>3D-Modellierung...<br /></h2>
        <p>Modellierung und Rendering in Blender.</p>
      </div>
    </div>
    <div class="img-stack img-gamedesign">
      <video
        autoplay
        muted
        loop
        playsinline
        aria-label="Game Design 101 – prozedurale Animation"
      >
        <source
          src="https://res.cloudinary.com/rhizomech/video/upload/f_webm,vc_vp9/GameDesign101_1080p_eoaems.webm"
          type="video/webm"
        />
        <source
          src="https://res.cloudinary.com/rhizomech/video/upload/f_mp4,vc_h264/GameDesign101_1080p_eoaems.mp4"
          type="video/mp4"
        />
      </video>
      <div class="img-caption">
        <h2>Prozedurale Animation in Houdini...<br /></h2>
      </div>
    </div>

    <div class="img-stack img-gjermundbu">
      <CldImage
        src="Gjermundbu_GalleryImages_1_sco2yz"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="UZH Blender Kurs"
      />
      <div class="img-caption">
        <h2>Handling von 3D-Scans und Daten...<br /></h2>
        <p>
          3D-Modell des Gjermundbu-Helms, aus frei verfügbaren Scandaten
          entstanden.
        </p>
      </div>
    </div>

    <div class="img-stack img-uzh-blender">
      <CldImage
        src="UZHBlenderCourse_1_r6kaar"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="UZH Blender Kurs"
      />
      <div class="img-caption">
        <h2>bis hin zur Lehre.<br /></h2>
        <p>Dozent für Blender-Kurse an der Universität Zürich (UZH).</p>
      </div>
    </div>

    <!-- chapter 7 -->
    <div class="text-wrapper text-p7-1">
      <p class="text-block">
        Da Information heute primär digital konsumiert wird, ist es mir wichtig,
        mich vertieft mit modernen interaktiven Formaten auseinanderzusetzen.
      </p>
    </div>

    <div class="img-stack img-xylo">
      <CldImage
        src="XylopediaInsta4_hjbuf8"
        width={1200}
        sizes="(max-width: 768px) 100vw, 50vw"
        alt="Xylopedia iPad App"
      />
      <div class="img-caption">
        <h2>Angefangen bei interaktiven 3D-Applikationen...<br /></h2>
        <p>
          App für die Vermittlung der Holzstrukturen an der Hochschule für
          Nachhaltige Entwicklung Eberswalde.
        </p>
      </div>
    </div>
    <div class="text-wrapper text-p7-2">
      <p class="text-block">
        Nun verlagert sich mein Fokus jedoch zunehmend auf das Web, da es das
        Publikum am direktesten erreicht.
      </p>
    </div>

    <div class="img-stack img-portfolio-video">
      <video autoplay muted loop playsinline aria-label="Portfolio">
        <source
          src="https://res.cloudinary.com/rhizomech/video/upload/f_webm,vc_vp9/Portfolio_lc2mft.webm"
          type="video/webm"
        />
        <source
          src="https://res.cloudinary.com/rhizomech/video/upload/f_mp4,vc_h264/Portfolio_lc2mft.mp4"
          type="video/mp4"
        />
      </video>
      <div class="img-caption">
        <h2>bis hin zu Coding & Design für das Web.<br /></h2>
        <p>Mein Portfolio rhizome.ch von Grund auf designt und programmiert.</p>
      </div>
    </div>
    <div class="text-wrapper text-block portfolio-link">
      <div class="logo-link"></div><a
        href="/"
        class="portfolio-logo-btn"
        aria-label="rhizome.ch"
      >
        &rarr; rhizome.ch
      </a>
    </div>
    <!-- <div class="text-wrapper text-p7-3">
      <p class="text-block">
        Das schönste Resultat ist für mich, wenn schliesslich verschiedene
        Disziplinen – 3D-Daten, Design und Web-Technologie – zu einem stimmigen
        Gesamterlebnis zusammenfinden.
      </p>
    </div> -->
  </div>
  <!-- #endregion -->

  <!-- #region Section: Zukunft (chapter 8) -->
  <div id="panel-zukunft" class="scrolly-panel split-panel">
    <div class="text-wrapper text-p8-1">
      <p class="text-block text-p8-2">
        Die NZZ steht für analytische Klarheit und besticht mit ihrem Visual
        Storytelling.
      </p>
      <p class="text-block text-p8-3">
        In Ihrem Umfeld, in dem Tempo und Kompetenz zusammenkommen, möchte ich
        meine Erfahrungen und mein technisches Repertoire einbringen. Ob
        schnelle, prägnante Arbeiten oder tiefgründige Auseinandersetzungen mit
        einem Thema – beides reizt mich gleichermassen.
      </p>
      <p class="text-block text-p8-4">
        Deswegen bewerbe ich mich als Volontär bei NZZ Visuals, um von Ihrem
        Team zu lernen und gemeinsam die Zukunft des visuellen Journalismus zu
        prägen.
      </p>

      <div class="text-wrapper text-p8-5">
        <h1 class="text-block">Vielen Dank für Ihre Zeit.</h1>
      </div>

      <div class="img-stack img-flower-canvas">
        <canvas id="flower-canvas"></canvas>
      </div>
    </div>
    <!-- #endregion -->

    <div id="image-sequences" data-flower={JSON.stringify(flowerUrls)}></div>
  </div>

  <!-- Progress bar is a sibling of all panels so panel opacity doesn't affect it -->
  <div id="scrolly-progress">
    <span class="progress-word active" data-section="intro">Intro</span>
    <span></span>
    <span class="progress-word" data-section="work">Work</span>
    <span></span>
    <span class="progress-word" data-section="werdegang">Werdegang</span>
    <span></span>
    <span class="progress-word" data-section="zukunft">Zukunft</span>
  </div>

  <script>
    // #region Imports & Setup
    import Lenis from "lenis";
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);
    // #endregion

    // #region Lenis Smooth Scroll
    const lenis = new Lenis({
      lerp: 0.1,
      wheelMultiplier: 1,
      smoothWheel: true,
    });
    lenis.on("scroll", ScrollTrigger.update);
    gsap.ticker.add((time) => {
      lenis.raf(time * 1000);
    });
    // #endregion

    // #region Master Timeline & Progress Update
    const masterTl = gsap.timeline({
      scrollTrigger: {
        trigger: "#scrolly-container",
        start: "top top",
        end: "+=3000%",
        scrub: 0.15,
        pin: true,
        markers: false,
        snap: {
          snapTo: "labels",
          duration: { min: 0.2, max: 3 },
          delay: 0.2,
          ease: "power1.inOut",
        },
        onUpdate: (self) => {
          const tl = self.animation;
          const time = tl.time();
          const labels = tl.labels;
          let active = "intro";
          if (time >= labels["chapter-8"]) active = "zukunft";
          else if (time >= labels["chapter-5"]) active = "werdegang";
          else if (time >= labels["chapter-3"]) active = "work";
          document.querySelectorAll(".progress-word").forEach((el) => {
            el.classList.toggle("active", el.dataset.section === active);
          });
        },
      },
    });
    // #endregion

    // #region Flower Splat Canvas
    const dataIsland = document.getElementById("image-sequences");
    const flowerUrls = JSON.parse(dataIsland.dataset.flower || "[]");

    const flowerCanvas = document.getElementById(
      "flower-canvas",
    ) as HTMLCanvasElement;
    const flowerCtx = flowerCanvas.getContext("2d");
    const flowerImages = [];
    const flowerPlayhead = { frame: 0 };

    flowerUrls.forEach((url) => {
      const img = new window.Image();
      img.src = url;
      flowerImages.push(img);
    });

    if (flowerImages.length > 0) {
      flowerImages[0].onload = () => {
        flowerCanvas.width = flowerImages[0].naturalWidth;
        flowerCanvas.height = flowerImages[0].naturalHeight;
        renderFlower();
      };
    }

    const renderFlower = () => {
      if (flowerImages.length === 0) return;
      flowerCtx.clearRect(0, 0, flowerCanvas.width, flowerCanvas.height);
      const frame = Math.min(
        Math.max(Math.round(flowerPlayhead.frame), 0),
        flowerImages.length - 1,
      );
      flowerCtx.drawImage(
        flowerImages[frame],
        0,
        0,
        flowerCanvas.width,
        flowerCanvas.height,
      );
    };
    // #endregion

    // #region GSAP Helper Functions
    // Helper functions
    let snapLabelCount = 0;

    const showText = (selector, sync = false) => {
      const result = masterTl.fromTo(
        selector,
        { opacity: 0, y: 40 },
        { opacity: 1, y: 0, duration: 0.3, ease: "power2.out" },
        sync ? "<" : "+=0.2",
      );
      masterTl.addLabel(`snap-${snapLabelCount++}`, ">");
      return result;
    };

    const hideText = (selector, sync = false) => {
      return masterTl.to(
        selector,
        { y: "-70vh", opacity: 0, duration: 0.5 },
        sync ? "<" : "+=0.2",
      );
    };

    const showImg = (selector, sync = false) => {
      const result = masterTl.fromTo(
        selector,
        { scale: 0.85, opacity: 0 },
        { scale: 1, opacity: 1, duration: 0.6, ease: "power2.out" },
        sync ? "<" : "-=0.2",
      );
      masterTl.addLabel(`snap-${snapLabelCount++}`, ">");
      return result;
    };

    const zoomFadeInImg = (selector, sync = false) => {
      const result = masterTl.fromTo(
        selector,
        { scale: 0.8, opacity: 0 },
        { opacity: 1, duration: 0.8, scale: 1, ease: "power2.out" },
        sync ? "<" : "-=0.5",
      );
      masterTl.addLabel(`snap-${snapLabelCount++}`, ">");
      return result;
    };

    const hideImg = (selector, sync = false) => {
      return masterTl.to(
        selector,
        { scale: 0.95, opacity: 0, duration: 0.4 },
        sync ? "<" : "+=0.2",
      );
    };
    // #endregion

    // #region Initial States & Animations
    // Scroll Indicator Animation
    const scrollIndicatorTween = gsap.to(".scroll-indicator", {
      opacity: 1,
      y: 50,
      duration: 1.2,
      delay: 0.5,
      repeat: -1,
      yoyo: true,
      ease: "power1.out",
    });

    const hideScrollIndicator = () => {
      scrollIndicatorTween.kill();
      gsap.to(".scroll-indicator", { opacity: 0, duration: 0.6 });
      lenis.off("scroll", hideScrollIndicator);
    };
    lenis.on("scroll", hideScrollIndicator);

    // #region GSAP Timeline Sequencing

    gsap.set(".intro-static", { opacity: 1, y: 0 });
    gsap.set(".intro-reveal-1", { opacity: 0, y: 0 });
    gsap.set(".intro-reveal-2", { opacity: 0, y: 0 });

    // #region Chapter 1: Intro — text then 3 images
    masterTl.addLabel("chapter-1");
    masterTl.set("#panel-intro", { opacity: 1 });
    masterTl.to("#scrolly-progress", { opacity: 1, duration: 0.2 });
    showText(".intro-reveal-1");
    showText(".intro-reveal-2");
    hideText(".text-p1");
    masterTl.to(".scroll-indicator", { opacity: 0, duration: 0.1 }, "<");

    showImg(".img-quercus", true);
    hideImg(".img-quercus");
    showImg(".img-buchdrucker", true);
    hideImg(".img-buchdrucker");
    showImg(".img-ub-intro", true);
    hideImg(".img-ub-intro");
    // #endregion

    // #region Chapter 3: Work — panel-intro stays visible; panel-work overlays it
    masterTl.addLabel("chapter-3");
    masterTl.to("#panel-work", { opacity: 1, duration: 0.05 });
    showText(".text-titel-work", true);
    hideText(".text-titel-work");
    showText(".text-p3-intro", true);
    hideText(".text-p3-intro");
    zoomFadeInImg(".img-pheno", true);
    hideImg(".img-pheno");
    zoomFadeInImg(".img-eth-vis-1", true);
    hideImg(".img-eth-vis-1");
    zoomFadeInImg(".img-microbiome", true);
    hideImg(".img-microbiome");
    showText(".text-p3-conclusion", true);
    hideText(".text-p3-conclusion");
    // #endregion

    // #region Chapter 5: Werdegang — fade out panel-intro (takes panel-work with it)
    masterTl.addLabel("chapter-5");
    masterTl.to("#panel-werdegang", { opacity: 1, duration: 0.05 });
    masterTl.to("#panel-intro", { opacity: 0, duration: 0.05 }, "<");
    showText(".text-p5-1", true);
    hideText(".text-p5-1");
    showImg(".img-illustration-1", true);
    hideImg(".img-illustration-1");
    zoomFadeInImg(".img-wood-12", true);
    hideImg(".img-wood-12");
    // #endregion

    // #region Chapter 6: Technologie & 3D
    masterTl.addLabel("chapter-6");
    showText(".text-p6", true);
    hideText(".text-p6");
    showImg(".img-bacteria", true);
    hideImg(".img-bacteria");
    zoomFadeInImg(".img-gamedesign", true);
    hideImg(".img-gamedesign");
    zoomFadeInImg(".img-gjermundbu", true);
    hideImg(".img-gjermundbu");
    zoomFadeInImg(".img-uzh-blender", true);
    hideImg(".img-uzh-blender");
    // #endregion

    // #region Chapter 7: Digitale Formate & Web
    masterTl.addLabel("chapter-7");
    showText(".text-p7-1", true);
    hideText(".text-p7-1");
    zoomFadeInImg(".img-xylo", true);
    hideImg(".img-xylo");
    showText(".text-p7-2", true);
    hideText(".text-p7-2");
    showImg(".img-portfolio-video", true);
    hideImg(".img-portfolio-video");
    showText(".portfolio-link", true);
    hideText(".portfolio-link");
    // #endregion

    // #region Chapter 8: Zukunft — 3 sequential text reveals, then flower + finale
    masterTl.addLabel("chapter-8");
    masterTl.to("#panel-zukunft", { opacity: 1, duration: 0.05 });
    masterTl.to("#panel-werdegang", { opacity: 0, duration: 0.05 }, "<");
    masterTl.to(".text-p8-1", { opacity: 1, duration: 0.05 }, "<");
    showText(".text-p8-2", true);
    showText(".text-p8-3");
    showText(".text-p8-4");
    hideText(".text-p8-2");
    hideText(".text-p8-3", true);
    hideText(".text-p8-4", true);
    masterTl.to(
      flowerPlayhead,
      {
        frame: (flowerImages.length || 1) - 1,
        snap: "frame",
        ease: "none",
        onUpdate: renderFlower,
        duration: 1.5,
      },
      "-=1",
    );
    showImg(".img-flower-canvas", true);
    showText(".text-p8-5");
    masterTl.addLabel(`text-snap-${snapLabelCount++}`);
    // #endregion

    // #endregion

    // #region Event Listeners
    // Clickable Progress Words
    document.querySelectorAll(".progress-word").forEach((word) => {
      word.addEventListener("click", (e) => {
        const target = e.currentTarget as HTMLElement;
        const section = target.dataset.section;
        let label = "chapter-1";
        if (section === "work") label = "chapter-3";
        else if (section === "werdegang") label = "chapter-5";
        else if (section === "zukunft") label = "chapter-8";

        if (masterTl.scrollTrigger) {
          const scrollPos = masterTl.scrollTrigger.labelToScroll(label) + 700;
          lenis.scrollTo(scrollPos, { duration: 4 });
        }
      });
    });
    // #endregion
  </script>

