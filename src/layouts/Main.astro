---
import { ClientRouter } from "astro:transitions";
import { fade } from "astro:transitions";
import Backdrop from "../components/Background.astro";

import "../styles/global.css";

import { getImage } from "astro:assets";
import ogImage from "../assets/Rhizome_OpenGraphImage_Main_ScientficIllustration.jpg";

// This forces Astro to process and include the image
const optimizedOgImage = await getImage({ src: ogImage });

const {
  title = "Rhizome Visuals — Scientific Illustration & 3D Design",
  description = "Scientific illustration and 3D design by Joshua Binswanger (Rhizome Visuals).",
} = Astro.props;

const isProd = import.meta.env.PROD;

// Per-page canonical / OG URL derived from the current route (not hardcoded),
// so each page is its own indexable entity rather than a duplicate of the homepage.
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(optimizedOgImage.src, Astro.site).toString();

// Structured data: tells search + AI answer engines who Joshua / Rhizome are
// and how the entities relate, instead of leaving them to infer it from prose.
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": "https://rhizome.ch/#person",
      name: "Joshua Binswanger",
      url: "https://rhizome.ch",
      email: "info@rhizome.ch",
      image: ogImageUrl,
      jobTitle: "Scientific Illustrator & 3D Designer",
      knowsAbout: [
        "Scientific Illustration",
        "3D Visualisation",
        "Data Visualisation",
        "Knowledge Visualisation",
        "Information Design",
        "SideFX Houdini",
        "Blender",
      ],
      worksFor: { "@id": "https://rhizome.ch/#org" },
    },
    {
      "@type": "ProfessionalService",
      "@id": "https://rhizome.ch/#org",
      name: "Rhizome Visuals",
      url: "https://rhizome.ch",
      image: ogImageUrl,
      email: "info@rhizome.ch",
      description:
        "Scientific illustration, 3D design and visualisation practice of Joshua Binswanger.",
      founder: { "@id": "https://rhizome.ch/#person" },
      areaServed: "Worldwide",
      serviceType: [
        "Scientific Illustration",
        "3D Design & Visualisation",
        "Drawing & Illustration",
        "Infographics",
        "Workshops",
      ],
    },
    {
      "@type": "WebSite",
      "@id": "https://rhizome.ch/#website",
      url: "https://rhizome.ch",
      name: "Rhizome Visuals",
      publisher: { "@id": "https://rhizome.ch/#person" },
    },
  ],
};
---

<html
  lang="en"
  style="height: 100%; margin: 0; padding: 0; -webkit-font-smoothing: auto; -moz-osx-font-smoothing: auto;"
  transition:animate={fade({ duration: "0.5s" })}
>
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <meta name="description" content={description} />
    <meta name="author" content="Joshua Binswanger" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- OG Tags -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta
      property="og:site_name"
      content="Rhizome Visuals - Scientific Illustration"
    />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Structured data (JSON-LD) -->
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(structuredData)}
    />

    <!-- Client Router -->
    <ClientRouter fallback="swap" />

    <!-- Umami Analytics Script -->
    {
      isProd && (
        <script
          is:inline
          defer
          src="https://cloud.umami.is/script.js"
          data-website-id="b091eee1-ced0-4ae9-bc1d-033243c323cc"
        />
      )
    }
  </head>
  <body>
    {/* We want the content of each page to go here */}
    <slot />
    <Backdrop transition:animate="none" transition:persist />
  </body>
</html>

<script>
  function _calculateScrollbarWidth() {
    document.documentElement.style.setProperty(
      "--scrollbar-width",
      window.innerWidth - document.documentElement.clientWidth + "px",
    );
  }
  // recalculate on resize
  window.addEventListener("resize", _calculateScrollbarWidth, false);
  // recalculate on dom load
  document.addEventListener(
    "DOMContentLoaded",
    _calculateScrollbarWidth,
    false,
  );
  // recalculate on load (assets loaded as well)
  window.addEventListener("load", _calculateScrollbarWidth);
  document.addEventListener("astro:page-load", _calculateScrollbarWidth);
</script>

<style>
  @import "../styles/global.css";

  html {
    background: var(--bg-color);
    scrollbar-gutter: stable;
    scrollbar-color: var(--bg-dark) var(--bg-color);
  }

  body {
    background: var(--bg-color);
    min-height: 100svh;
    margin: 0;
    display: grid;
    grid-template-rows: 1fr auto;
    font-family: PowerGrotesk-Light;
    overflow-x: hidden;
    overflow-y: auto;
    max-width: 100vw;

    @media (--bp-mobile) {
      grid-template-rows: 0px 1fr auto;
    }
  }

  ::-webkit-scrollbar-track {
    background: var(--bg-color);
  }

  ::-webkit-scrollbar-corner {
    background: var(--bg-color);
  }
</style>
